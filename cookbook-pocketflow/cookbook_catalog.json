{
  "_comment": "PocketFlow migration cookbook catalog — 42 recipes migrated from https://github.com/The-Pocket/PocketFlow/tree/main/cookbook",
  "_schema": {
    "id": "zero-padded recipe number (e.g. '001')",
    "name": "human-readable recipe name",
    "description": "one-line description of what the recipe demonstrates",
    "args": "default spl3 run invocation as a list (adapter/model overridden by --adapter/--model flags at runtime)",
    "dir": "recipe directory name relative to cookbook-pocketflow/",
    "log": "log file prefix (timestamp appended at runtime)",
    "is_active": "false = not yet validated; set to true after passing spl3 validate + spot-check run",
    "approval_status": "new | approved | wip | disabled",
    "category": "basics | agentic | multi-agent | reasoning | retrieval | application | safety | multimodal | cloud_infrastructure",
    "tier": "1=beginner 2=intermediate 3=advanced (optional)",
    "excluded_adapters": "list of adapters that cannot run this recipe (optional)",
    "requires": "system-level requirements such as API keys or local services (optional)",
    "notes": "migration notes or known issues (optional)"
  },
