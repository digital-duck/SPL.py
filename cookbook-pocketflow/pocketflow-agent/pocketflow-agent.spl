CREATE FUNCTION decide_action(question TEXT, context TEXT) RETURNS TEXT AS $$
  You are a research agent. Given the question and accumulated context below, reason step-by-step and decide your next action.

  Question: {question}

  Accumulated context:
  {context}

  Respond with valid YAML in exactly this format:
  action: search        # use "search" if you need more information, "answer" if you are confident enough
  reasoning: <one sentence explaining your choice>
  query: <specific search query>    # required when action is "search"

  Output only the YAML block. No prose before or after.
$$;

CREATE FUNCTION repair_yaml(malformed TEXT) RETURNS TEXT AS $$
  The following output is malformed or invalid YAML. Repair it so it strictly conforms to this schema:
    action: search|answer
    reasoning: <text>
    query: <text, required when action is search>

  Return only the corrected YAML. Do not include any explanation or surrounding text.

  Malformed input:
  {malformed}
$$;

CREATE FUNCTION fetch_results(decision TEXT) RETURNS TEXT AS $$
  Parse the "query" field from the following YAML decision:
  {decision}

  Perform a DuckDuckGo web search for that query and return the top 3-5 result snippets as concise bullet points, each prefixed with its source URL.
$$;

CREATE FUNCTION synthesize_answer(question TEXT, context TEXT) RETURNS TEXT AS $$
  Using the research context below, write a comprehensive and well-structured answer to the question.

  Question: {question}

  Research context:
  {context}

  Provide a clear, factual prose answer with references to gathered evidence where appropriate.
$$;

WORKFLOW react_research_agent
  INPUT @question TEXT, @max_iterations NUMBER := 3
  OUTPUT @answer TEXT
DO
  @context := @question;
  @iteration := 0;

  WHILE @iteration < @max_iterations DO
    DO
      GENERATE decide_action(@question, @context) INTO @decision;
    EXCEPTION
      WHEN HallucinationDetected THEN
        GENERATE repair_yaml(@decision) INTO @decision;
    END;

    EVALUATE @decision
      WHEN contains('action: search') THEN
        GENERATE fetch_results(@decision) INTO @snippets;
        @context := @context + '\n\n--- Research pass ' + @iteration + ' ---\n' + @snippets;
        @iteration := @iteration + 1;
      WHEN contains('action: answer') THEN
        GENERATE synthesize_answer(@question, @context) INTO @answer;
        RETURN @answer WITH status = 'done', iterations = @iteration;
      ELSE
        @iteration := @iteration + 1;
    END;
  END;

  GENERATE synthesize_answer(@question, @context) INTO @answer;
  RETURN @answer WITH status = 'max_iterations', iterations = @iteration;
EXCEPTION
  WHEN BudgetExceeded THEN
    GENERATE synthesize_answer(@question, @context) INTO @answer;
    RETURN @answer WITH status = 'budget_limit';
END;