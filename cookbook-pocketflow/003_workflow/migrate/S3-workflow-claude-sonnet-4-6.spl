CREATE TOOL_API parse_outline_sections(yaml_outline TEXT) RETURNS TEXT AS PYTHON $$
import yaml, json
def parse_outline_sections(yaml_outline: str) -> str:
    try:
        raw = yaml_outline.strip()
        if raw.startswith("```"):
            raw = "\n".join(raw.split("\n")[1:-1])
        data = yaml.safe_load(raw)
        if isinstance(data, dict):
            sections = data.get(''sections'', data.get(''outline'', []))
        elif isinstance(data, list):
            sections = data
        else:
            return "error: unrecognized outline format"
        if not sections:
            return "error: no sections found"
        return json.dumps([str(s) for s in sections])
    except Exception as e:
        return f"error: {e}"
$$;

CREATE TOOL_API get_section_by_index(sections_json TEXT, idx TEXT) RETURNS TEXT AS PYTHON $$
import json
def get_section_by_index(sections_json: str, idx: str) -> str:
    try:
        sections = json.loads(sections_json)
        i = int(idx)
        return sections[i] if 0 <= i < len(sections) else ""
    except Exception as e:
        return f"error: {e}"
$$;

CREATE FUNCTION generate_outline(topic TEXT)
RETURNS TEXT AS $$
Generate a structured article outline for the topic: "{topic}"

Return ONLY a YAML document in this exact format:
sections:
  - <section title>
  - <section title>

Include 4-6 sections covering introduction, key points, and conclusion.
Output ONLY valid YAML — no extra text, no code fences.
$$;

CREATE FUNCTION draft_section(topic TEXT, section_title TEXT, outline TEXT)
RETURNS TEXT AS $$
Write a detailed draft for the section "{section_title}" in an article about {topic}.

Full outline for context:
{outline}

Write 2-4 well-structured paragraphs for this section only. Do not include other sections.
$$;

CREATE FUNCTION polish_article(topic TEXT, full_draft TEXT)
RETURNS TEXT AS $$
Rewrite the following article draft about {topic} with a polished, conversational style.
Ensure smooth transitions between sections, a consistent voice, and a compelling narrative flow.

Draft:
{full_draft}

Output the complete, publication-ready article.
$$;

WORKFLOW article_writer
  INPUT @topic TEXT
  INPUT @max_sections INTEGER := 8
  OUTPUT @article TEXT
DO
  -- Step 1: generate YAML outline
  GENERATE generate_outline(@topic) INTO @yaml_outline;
  CALL parse_outline_sections(@yaml_outline) INTO @sections_json;

  EVALUATE @sections_json WHEN contains("error") THEN
    @article := "Error: Invalid outline — " + @sections_json;
  ELSE
    -- Step 2: draft each section (parallel per diagram — loop over dynamic N)
    @i := 0;
    @all_drafts := "";
    WHILE @i < @max_sections DO
      CALL get_section_by_index(@sections_json, @i) INTO @section_title;
      CALL isblank(@section_title) INTO @is_blank;
      CALL lower(@is_blank) INTO @is_blank;
      EVALUATE @is_blank WHEN contains("true") THEN
        @i := @max_sections;
      ELSE
        GENERATE draft_section(@topic, @section_title, @yaml_outline) INTO @section_draft;
        @all_drafts := @all_drafts + "## " + @section_title + "
" + @section_draft + "
";
        @i := @i + 1;
      END;
    END;
    -- Step 3: style rewriting
    GENERATE polish_article(@topic, @all_drafts) INTO @article;
  END;
  RETURN @article WITH status = "complete";
END;