-- ============================================================
-- Recipe 66: Mixed-Regime Stock Analysis
--
-- Demonstrates the 2×2 hybrid matrix:
--   Deterministic (TOOL_API) — data fetch + numeric filter
--   Probabilistic  (CREATE FUNCTION + GENERATE) — LLM insight
--
-- Regime principle: use Python for what Python can unit-test;
-- use the LLM only for reasoning and text generation.
-- ============================================================

-- ── Deterministic regime: Python tools ───────────────────────

CREATE TOOL_API fetch_ohlcv(ticker TEXT, days TEXT)
RETURNS TEXT AS PYTHON $$
import urllib.request, json, datetime

def fetch_ohlcv(ticker: str, days: str) -> str:
    """Fetch recent OHLCV data from Yahoo Finance (no API key needed)."""
    try:
        n = int(days)
        end_ts   = int(datetime.datetime.utcnow().timestamp())
        start_ts = end_ts - n * 86400
        url = (
            f"https://query1.finance.yahoo.com/v8/finance/chart/{ticker}"
            f"?period1={start_ts}&period2={end_ts}&interval=1d"
        )
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        result = data["chart"]["result"][0]
        times  = result["timestamp"]
        closes = result["indicators"]["quote"][0]["close"]
        rows   = []
        for t, c in zip(times, closes):
            if c is None:
                continue
            date = datetime.datetime.utcfromtimestamp(t).strftime("%Y-%m-%d")
            rows.append(f"{date},{round(c, 2)}")
        return "date,close\n" + "\n".join(rows) if rows else "error: no data"
    except Exception as e:
        return f"error: {e}"
$$;

CREATE TOOL_API compute_metrics(csv_data TEXT)
RETURNS TEXT AS PYTHON $$
def compute_metrics(csv_data: str) -> str:
    """Compute simple price metrics from date,close CSV."""
    try:
        lines = [l for l in csv_data.strip().splitlines() if l and not l.startswith("date")]
        if not lines:
            return "error: empty data"
        closes = []
        for line in lines:
            parts = line.split(",")
            if len(parts) >= 2:
                try:
                    closes.append(float(parts[1]))
                except ValueError:
                    pass
        if len(closes) < 2:
            return "error: insufficient data"
        start_p = closes[0]
        end_p   = closes[-1]
        high_p  = max(closes)
        low_p   = min(closes)
        change  = round((end_p - start_p) / start_p * 100, 2)
        avg_p   = round(sum(closes) / len(closes), 2)
        return (
            f"start={start_p},end={end_p},high={high_p},"
            f"low={low_p},change_pct={change},avg={avg_p},n={len(closes)}"
        )
    except Exception as e:
        return f"error: {e}"
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION interpret_metrics(ticker TEXT, metrics TEXT)
RETURNS TEXT AS $$
You are a financial analyst. Given the following price metrics for {ticker},
write a concise two-sentence summary covering:
  1. Overall trend direction (bullish / bearish / sideways).
  2. One key risk or opportunity based on the data.

Metrics: {metrics}
$$;

CREATE FUNCTION synthesize_report(tickers TEXT, summaries TEXT, days INT)
RETURNS TEXT AS $$
You are a portfolio manager. Given the following per-stock summaries for {tickers},
produce a brief (3–5 sentence) consolidated portfolio outlook that:
  - opens with the tickers and time frame,
  - Highlights the best and worst performers.
  - Notes any correlated risk across the portfolio.
  - Ends with a single actionable recommendation.

Summaries:
{summaries}
$$;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW stock_analysis
  INPUT @tickers TEXT := 'AAPL,META,GOOG, CRM'
  INPUT @days INT := 30
  OUTPUT @report TEXT
DO
  @report := '';

  -- Native LIST iteration: splits @tickers by comma automatically
  WHILE @ticker IN @tickers DO
    CALL fetch_ohlcv(@ticker, @days) INTO @raw_data;
    CALL compute_metrics(@raw_data) INTO @metrics;
    GENERATE interpret_metrics(@ticker, @metrics) INTO @insight;
    @report := @report + @ticker + ': ' + @insight + '\n\n';
  END;

  -- Final LLM synthesis across all tickers
  GENERATE synthesize_report(@tickers, @report, @days) INTO @synthesis;
  @report := @synthesis;

  RETURN @report WITH status = 'complete';
EXCEPTION
  WHEN BudgetExceeded THEN
    RETURN @report WITH status = 'budget_limit';
END;
