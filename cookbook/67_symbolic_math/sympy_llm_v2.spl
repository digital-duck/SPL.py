-- ============================================================
-- Recipe 67c v2: sympy_llm_v2 — A/B harness + plan-sanity gate
--
-- Delta from sympy_llm.spl: two LLM sanity gates, both binary
-- (pass / fail | reason), both one-directional — they can only
-- withhold, never vouch; the math is vouched for by the kernel alone:
--   plan gate  (checkpoint 2, pre-execution):  decomposed plan vs problem
--   chain gate (checkpoint 4, post-execution): verified trace vs problem
--
-- Fail-fast policy inherited from sympy_llm.spl: any failure in the
-- verified path exits immediately with an explicit status, no LLM
-- fallback — arm B (enable_solver=false) IS the unaided baseline, so a
-- model that cannot even decompose the problem fails fast here rather
-- than degrading into the very thing arm B measures.
--
-- Requires: pip install sympy (or run with --self-healing)
-- ============================================================

IMPORT 'sympy_tools'

-- Gate prompts live here (not in sympy_tools) so the v1 harness stays
-- untouched for A/B runs. Binary one-line verdict: pass / fail.


-- ── One chain step, CALLed once per item ─────────────────────
-- _v2 suffix avoids a registry collision when this file and
-- sympy_llm.spl load side by side.

WORKFLOW solve_chain_step_v2
  INPUT @step TEXT
  INPUT @running_expression TEXT := ""
  OUTPUT @step_summary TEXT
DO
  CALL split_part(@step, '|', '1') INTO @raw_expression;
  CALL split_part(@step, '|', '2') INTO @operation;

  -- Resolve PREV deterministically (lower-case both sides: EVALUATE
  -- lower-cases the literal but not the value).
  CALL lower(@raw_expression) INTO @raw_expression_lc;
  EVALUATE @raw_expression_lc
    WHEN = 'prev' THEN
      @expression := @running_expression
    ELSE
      @expression := @raw_expression
  END

  CALL solve_step_with_sympy(@expression, @operation) INTO @step_summary;

  -- '<bare_result>|<human_readable_line>'; bare_result is 'sympy_error'
  -- on failure — the caller fail-fasts on it.
  RETURN @step_summary
END;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW math_solver_ab_v2
  INPUT @problem TEXT := 'differentiate 3*x**3 - x, then factor if needed, finally solve for x'
  INPUT @log_dir TEXT := 'cookbook/67_symbolic_math/logs-spl'
  INPUT @enable_solver TEXT := 'true'
  OUTPUT @explanation TEXT
DO
  CALL lower(@enable_solver) INTO @solver_mode;

  -- WHEN needs an operator (`=`/`IS`/`IN`) — a bare literal would parse
  -- as an LLM-judged SemanticCondition.
  EVALUATE @solver_mode
    WHEN IN ('true', '1', 'yes') THEN
      @use_solver := 'yes'
    ELSE
      @use_solver := 'no'
  END

  EVALUATE @use_solver
    WHEN = 'yes' THEN
      DO
        -- ── ARM A: plan -> verified SymPy chain -> sanity gate -> explain ──
        LOGGING f"[arm=solver] Problem: '{@problem}' — planning the chain ..." LEVEL INFO

        GENERATE decompose_problem(@problem) INTO @steps_text;
        CALL trim(@steps_text) INTO @steps_text;
        CALL step_count(@steps_text) INTO @n_steps;

        LOGGING f"[arm=solver] decomposed into {@n_steps} step(s):\n\n\n{@steps_text}\n\n" LEVEL INFO

        -- Checkpoint 1: unusable plan (structural) — exit before computing.
        EVALUATE @n_steps
          WHEN = '0' THEN
            LOGGING f'[arm=solver] PLAN FAILURE — decompose_problem produced no usable steps' LEVEL ERROR
            CALL write_file(f'{@log_dir}/chain_trace.md',
              f'(planning failed — raw decomposition output below)\n{@steps_text}') INTO NONE;
            RETURN f'[PLAN FAILURE] The planning step could not decompose "{@problem}" into usable operations.\nRaw decomposition output: {@steps_text}'
              WITH status = 'plan_error', arm = 'solver', steps = 0
        END

        -- Checkpoint 2a (deterministic, 0-token): chain-protocol format —
        -- line 1 carries the expression, every later line is PREV|<op>.
        CALL validate_plan(@steps_text) INTO @plan_format;
        EVALUATE @plan_format
          WHEN IS NOT 'ok' THEN
            LOGGING f'[arm=solver] PLAN FORMAT FAILURE — {@plan_format}' LEVEL ERROR
            CALL write_file(f'{@log_dir}/chain_trace.md',
              f'(plan failed the deterministic format check)\n{@steps_text}\nPLAN FORMAT: {@plan_format}\n') INTO NONE;
            RETURN f'[PLAN FORMAT FAILURE] The decomposed plan violates the chain protocol: {@plan_format}\nPlan:\n{@steps_text}'
              WITH status = 'plan_format_error', arm = 'solver', steps = 0
        END

        -- Checkpoint 2b (LLM): plan sanity gate — a model that cannot
        -- decompose the problem fails fast BEFORE any kernel work.
        GENERATE sanity_check_plan(@problem, @steps_text) INTO @plan_verdict_raw;
        CALL split_part(@plan_verdict_raw, '|', '1') INTO @plan_verdict;
        CALL lower(@plan_verdict) INTO @plan_verdict;

        EVALUATE @plan_verdict
          WHEN IS NOT 'pass' THEN
            LOGGING f'[arm=solver] PLAN SANITY FAILURE — gate verdict: {@plan_verdict} (raw: {@plan_verdict_raw})' LEVEL ERROR
            CALL write_file(f'{@log_dir}/chain_trace.md',
              f'(plan failed the sanity gate)\n{@steps_text}\nPLAN SANITY: {@plan_verdict_raw}\n') INTO NONE;
            RETURN f'[PLAN SANITY FAILURE] The decomposed plan does not set up the problem as asked.\nGate verdict: {@plan_verdict_raw}\nPlan:\n{@steps_text}'
              WITH status = 'plan_sanity_error', arm = 'solver', steps = 0
        END

        LOGGING f'[arm=solver] plan sanity gate: pass' LEVEL INFO

        @i := 0
        @running_expression := ""
        @trace := ""

        WHILE @i < @n_steps DO
          CALL extract_step(@steps_text, @i) INTO @step;
          CALL solve_chain_step_v2(@step, @running_expression) INTO @step_summary;
          CALL split_part(@step_summary, '|', '1') INTO @running_expression;
          CALL split_part(@step_summary, '|', '2') INTO @trace_line;

          @step_no := @i + 1

          -- Checkpoint 3: kernel rejected this step — exit with the
          -- verified prefix preserved for diagnosis.
          EVALUATE @running_expression
            WHEN = 'sympy_error' THEN
              LOGGING f'[arm=solver] SOLVER FAILURE at step {@step_no}/{@n_steps}: {@trace_line}' LEVEL ERROR
              CALL write_file(f'{@log_dir}/chain_trace.md',
                f'{@trace}{@step_no}. SOLVER ERROR — {@trace_line}\n') INTO NONE;
              RETURN f'[SOLVER FAILURE] Step {@step_no}/{@n_steps} could not be computed: {@trace_line}\nVerified chain up to this point:\n{@trace}'
                WITH status = 'solver_error', arm = 'solver', steps = @step_no
          END

          @trace := @trace + f'{@step_no}. {@trace_line}\n'
          LOGGING f'[arm=solver][step {@step_no}/{@n_steps}] {@trace_line}' LEVEL INFO
          @i := @i + 1
        END

        CALL write_file(f'{@log_dir}/chain_trace.md', @trace) INTO NONE;

        -- Checkpoint 4: chain sanity gate. Binary verdict — first '|'
        -- field, lower-cased; anything but 'pass' (including an empty
        -- or malformed reply) fails fast.
        GENERATE sanity_check_chain(@problem, @trace) INTO @verdict_raw;
        CALL split_part(@verdict_raw, '|', '1') INTO @verdict;
        CALL lower(@verdict) INTO @verdict;

        EVALUATE @verdict
          WHEN IS NOT 'pass' THEN
            LOGGING f'[arm=solver] SANITY FAILURE — gate verdict: {@verdict_raw}' LEVEL ERROR
            CALL write_file(f'{@log_dir}/chain_trace.md',
              f'{@trace}\nSANITY: {@verdict_raw}\n') INTO NONE;
            RETURN f'[SANITY FAILURE] The chain verified correctly but the sanity gate did not pass it.\nGate verdict: {@verdict_raw}\nVerified chain:\n{@trace}'
              WITH status = 'sanity_error', arm = 'solver', steps = @n_steps
        END

        LOGGING f'[arm=solver] sanity gate: pass — chain answers the problem as asked' LEVEL INFO

        GENERATE explain_chain(@problem, @trace) INTO @explanation;
        CALL trim(@explanation) INTO @explanation;

        -- Checkpoint 5: empty narration — surface the verified chain
        -- itself; a retry is still a fallback to the same unreliable step.
        EVALUATE @explanation
          WHEN = "" THEN
            LOGGING f'[arm=solver] NARRATION FAILURE — explain_chain returned empty content' LEVEL ERROR
            RETURN f'[NARRATION FAILURE] The chain verified correctly but the explanation step returned nothing.\nVerified chain:\n{@trace}'
              WITH status = 'narration_error', arm = 'solver', steps = @n_steps
        END

        RETURN @explanation WITH status = 'complete', arm = 'solver', steps = @n_steps
      END

    ELSE
      DO
        -- ── ARM B: unaided LLM, one shot (no gate — it would
        -- contaminate the A/B contrast) ──
        LOGGING f"[arm=llm_only] Problem '@{@problem}' — solving with NO symbolic kernel" LEVEL INFO

        CALL write_file(f'{@log_dir}/chain_trace.md',
          '(solver disabled for this run — no verified chain; the LLM solved it unaided)\n') INTO NONE;

        GENERATE solve_directly(@problem) INTO @explanation;
        CALL trim(@explanation) INTO @explanation;

        EVALUATE @explanation
          WHEN = "" THEN
            LOGGING f'[arm=llm_only] FAILURE — solve_directly returned empty content' LEVEL ERROR
            RETURN '[FAILURE] The unaided LLM returned nothing for this problem.'
              WITH status = 'llm_error', arm = 'llm_only', steps = 0
        END

        RETURN @explanation WITH status = 'complete', arm = 'llm_only', steps = 0
      END
  END
EXCEPTION
  WHEN BudgetExceeded THEN
    RETURN @explanation WITH status = 'budget_limit'
END;
