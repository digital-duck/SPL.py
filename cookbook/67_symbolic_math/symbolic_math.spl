-- ============================================================
-- Recipe 67: Symbolic Math Solver
--
-- Demonstrates the kernel as deterministic/symbolic substrate:
--
--   Probabilistic  (LLM)   — parse natural language problem
--                             into a SymPy expression + operation
--   Deterministic  (SymPy)  — exact symbolic computation via kernel
--   Probabilistic  (LLM)   — explain the result in plain English
--
-- The LLM never approximates the math. SymPy computes it exactly.
-- The LLM only handles the two parts it is uniquely suited for:
-- understanding the question and explaining the answer.
--
-- Requires: pip install sympy
--   (or run with --self-healing for automatic install)
-- ============================================================

-- ── Deterministic regime: SymPy via kernel ────────────────────

CREATE TOOL_API solve_with_sympy(expression TEXT, operation TEXT)
RETURNS TEXT AS PYTHON $$
def solve_with_sympy(expression: str, operation: str) -> str:
    """Exact symbolic computation. Imports SymPy at call time so the
    kernel can auto-install it on first use with --self-healing."""
    from sympy import (
        symbols, sympify, solve, diff, integrate,
        simplify, expand, factor, limit, oo
    )

    try:
        x, y, z, n = symbols('x y z n')
        expr = sympify(expression.strip())
        op = operation.strip().lower()

        if op in ('solve', 'roots', 'zeros'):
            result = solve(expr, x)
            return f"solve({expression} = 0) → x = {result}"
        elif op in ('diff', 'differentiate', 'derivative', 'gradient'):
            result = diff(expr, x)
            return f"d/dx({expression}) = {result}"
        elif op in ('integrate', 'integral', 'antiderivative'):
            result = integrate(expr, x)
            return f"∫ {expression} dx = {result} + C"
        elif op == 'simplify':
            result = simplify(expr)
            return f"simplify({expression}) = {result}"
        elif op == 'expand':
            result = expand(expr)
            return f"expand({expression}) = {result}"
        elif op == 'factor':
            result = factor(expr)
            return f"factor({expression}) = {result}"
        else:
            result = simplify(expr)
            return f"{expression} = {result}"
    except Exception as e:
        return f"sympy_error: {e}"
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION parse_math_problem(problem TEXT)
RETURNS TEXT AS $$
Convert this math problem into SymPy notation.
Reply with exactly one line in this format (no other text):
  <expression>|<operation>

Rules:
- Use Python/SymPy syntax: ** for powers, * for multiplication, sqrt(x), sin(x), exp(x), log(x)
- operation must be exactly one of: solve, diff, integrate, simplify, expand, factor
- For "solve", write f(x) with everything moved to the left side (= 0 form)

Examples:
  "find the roots of x squared minus 5x plus 6"   →  x**2 - 5*x + 6|solve
  "differentiate 3x cubed plus 2x"                →  3*x**3 + 2*x|diff
  "integrate sine of x"                            →  sin(x)|integrate
  "factor x squared minus 9"                       →  x**2 - 9|factor
  "simplify (x^2-1)/(x-1)"                         →  (x**2 - 1)/(x - 1)|simplify

Problem: {problem}
$$;

CREATE FUNCTION explain_solution(problem TEXT, sympy_result TEXT)
RETURNS TEXT AS $$
A student asked: "{problem}"

The symbolic math engine computed: {sympy_result}

Write a clear, friendly explanation (3–5 sentences) that:
1. Restates what the problem is asking in plain English
2. States the exact answer from the computation above
3. Briefly explains the key concept or method used
Do not re-derive the answer — trust the symbolic result above as exact.
$$;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW math_solver
  INPUT @problem TEXT := 'find the roots of x squared minus 5x plus 6'
  OUTPUT @explanation TEXT
DO
  -- Step 1 (probabilistic): LLM parses NL problem → SymPy expression|operation
  GENERATE parse_math_problem(@problem) INTO @parsed;
  CALL trim(@parsed) INTO @parsed;

  -- Extract expression and operation by splitting on '|'
  CALL split_part(@parsed, '|', '1') INTO @expression;
  CALL split_part(@parsed, '|', '2') INTO @operation;
  CALL trim(@expression) INTO @expression;
  CALL trim(@operation) INTO @operation;

  -- Step 2 (deterministic): SymPy computes exact result in the kernel
  CALL solve_with_sympy(@expression, @operation) INTO @sympy_result;

  -- Step 3 (probabilistic): LLM explains the exact result in plain English
  GENERATE explain_solution(@problem, @sympy_result) INTO @explanation;

  RETURN @explanation WITH status = 'complete';
EXCEPTION
  WHEN BudgetExceeded THEN
    RETURN @sympy_result WITH status = 'budget_limit';
END;
