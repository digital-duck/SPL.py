-- ============================================================
-- Recipe 67c: sympy_llm — an A/B harness for "architecture vs. scale"
--
-- Same kernel shape as sympy_math_multi_step.spl — decompose (LLM) ->
-- verified chain (SymPy) -> explain (LLM) — but wrapped behind ONE
-- boolean switch, @enable_solver, so the SAME problem and SAME model
-- can be run through two arms with a single --param flip:
--
--   @enable_solver = true   (architecture arm — the recipe-67 pattern)
--     Probabilistic (LLM)   — plan: decompose into an ordered chain
--     Deterministic (SymPy) — compute each step exactly, verified
--     Probabilistic (LLM)   — explain the verified chain
--
--   @enable_solver = false  (baseline arm — no kernel)
--     Probabilistic (LLM)   — solve the WHOLE problem itself, one shot,
--                             with no symbolic engine backing it up
--
-- This operationalizes RQ1 from case-2-hackernews.md: does "small model
-- + deterministic kernel beats big model alone" hold because the kernel
-- is doing real work, or would the LLM have gotten there anyway? Now
-- both arms are one flag apart — same model, same problem, same prompt
-- shapes wherever possible — which is as close to a controlled A/B as
-- a single-process experiment gets.
--
-- Fail-fast policy (deliberate, not an oversight):
-- When @enable_solver is on, ANY failure inside the verified chain —
-- a plan that decomposes into nothing usable, a step SymPy can't
-- parse, or a narration that comes back empty — exits IMMEDIATELY
-- with an explicit error status and NO fallback to the LLM. We do
-- not ask the LLM to paper over a kernel-side failure: that would
-- reintroduce exactly the hallucination risk this architecture
-- exists to remove, and would make "the chain verified cleanly" and
-- "the chain failed but the LLM smoothed it over" indistinguishable
-- in the output — precisely the ambiguity the lfm2.5 run in
-- case-2.md exposed (steps=0, yet a fluent, unverified "complete").
-- A loud, attributable failure is more useful data than a quiet,
-- lucky-looking save.
--
-- Requires: pip install sympy (or run with --self-healing)
-- ============================================================

-- ── Deterministic regime: SymPy + step bookkeeping via kernel ──
-- (identical to sympy_math_multi_step.spl — same exact-computation
--  contract; duplicated here so this file runs standalone)

CREATE TOOL_API solve_step_with_sympy(expression TEXT, operation TEXT)
RETURNS TEXT AS PYTHON $$
def solve_step_with_sympy(expression: str, operation: str) -> str:
    """Exact symbolic computation for ONE step in a chain.

    Returns '<bare_result>|<human_readable_line>' so the caller can
    both (a) feed <bare_result> into the next step verbatim and
    (b) keep a readable trace — never asking the LLM to parse
    SymPy's own output back into an expression. On failure, returns
    'sympy_error|<expression>: <exception>' — a sentinel the caller
    checks for explicitly (see the fail-fast WHILE loop below)."""
    from sympy import symbols, sympify, solve, diff, integrate, simplify, expand, factor

    try:
        x, y, z, n = symbols('x y z n')
        expr = sympify(expression.strip())
        op = operation.strip().lower()

        if op in ('solve', 'roots', 'zeros'):
            result = solve(expr, x)
            return f"{result}|solve({expression} = 0) -> x = {result}"
        elif op in ('diff', 'differentiate', 'derivative', 'gradient'):
            result = diff(expr, x)
            return f"{result}|d/dx({expression}) = {result}"
        elif op in ('integrate', 'integral', 'antiderivative'):
            result = integrate(expr, x)
            return f"{result}|integral of {expression} dx = {result} + C"
        elif op == 'simplify':
            result = simplify(expr)
            return f"{result}|simplify({expression}) = {result}"
        elif op == 'expand':
            result = expand(expr)
            return f"{result}|expand({expression}) = {result}"
        elif op == 'factor':
            result = factor(expr)
            return f"{result}|factor({expression}) = {result}"
        else:
            result = simplify(expr)
            return f"{result}|{expression} = {result}"
    except Exception as e:
        return f"sympy_error|{expression}: {e}"
$$;

CREATE TOOL_API step_count(steps_text TEXT)
RETURNS TEXT AS PYTHON $$
def step_count(steps_text: str) -> str:
    """Deterministic, 0-token: counts non-blank lines in the
    decomposed step list (mirrors chunk_plan in recipe 13)."""
    return str(len([line for line in steps_text.splitlines() if line.strip()]))
$$;

CREATE TOOL_API extract_step(steps_text TEXT, index TEXT)
RETURNS TEXT AS PYTHON $$
def extract_step(steps_text: str, index: str) -> str:
    """Deterministic, 0-token: returns the i-th non-blank line of
    the decomposed step list (mirrors extract_chunk in recipe 13)."""
    lines = [line.strip() for line in steps_text.splitlines() if line.strip()]
    i = int(index)
    return lines[i] if 0 <= i < len(lines) else ""
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION decompose_problem(problem TEXT)
RETURNS TEXT AS $$
This math problem needs MORE THAN ONE symbolic operation, performed
in order, where each later operation acts on the PREVIOUS step's result.

Break it into an ordered list of steps, one per line, in this format
(no other text, no numbering, no blank lines):
  <expression>|<operation>

Rules:
- The FIRST step's <expression> is the starting expression, in Python/SymPy
  syntax (** for powers, * for multiplication, sqrt(x), sin(x), exp(x), log(x))
- Every step AFTER the first must use the literal placeholder PREV in place
  of <expression> — it means "the result of the previous step"
- operation must be exactly one of: solve, diff, integrate, simplify, expand, factor
- If the problem only needs ONE operation, reply with a single line

Examples:
  "differentiate e to the x and then simplify the result"
    ->  exp(x)|diff
        PREV|simplify

  "expand (x+1) squared, then factor the expanded form"
    ->  (x + 1)**2|expand
        PREV|factor

  "find the roots of x squared minus 4"
    ->  x**2 - 4|solve

Problem: {problem}
$$;

CREATE FUNCTION explain_chain(problem TEXT, trace TEXT)
RETURNS TEXT AS $$
A student asked: "{problem}"

The symbolic math engine computed this chain of EXACT steps, in order:
{trace}

Write a clear, friendly explanation in less than 6 sentences that:
1. Restates what the problem is asking in plain English
2. Walks through the chain step by step, in order, stating each exact result
3. Gives the final answer plainly at the end
Do not re-derive any step — trust the computed chain above as exact.
$$;

CREATE FUNCTION solve_directly(problem TEXT)
RETURNS TEXT AS $$
A student asked: "{problem}"

There is NO symbolic math engine backing you up this time — every
computation must be done correctly by you, from scratch.

Write a clear, friendly walkthrough in less than 8 sentences that:
1. Restates what the problem is asking in plain English
2. Shows your own working, step by step, in order — state the exact
   result of each step as you derive it (do not skip steps)
3. Gives the final answer plainly at the end

Show your work. Do not state any result you have not derived above.
$$;

-- ── Reusable sub-workflow: ONE chain step, CALLed once per item ──
-- Renamed from sympy_math_multi_step.spl's `solve_one_step` to avoid
-- a registry name collision when both files in this directory load
-- side by side (same "WORKFLOW calls WORKFLOW" pattern either way —
-- see critique_workflow in cookbook/05_v3_self_refine/self_refine.spl)

WORKFLOW solve_chain_step
  INPUT @step TEXT
  INPUT @running_expression TEXT := ''
  OUTPUT @step_summary TEXT
DO
  CALL split_part(@step, '|', '1') INTO @raw_expression;
  CALL split_part(@step, '|', '2') INTO @operation;
  CALL trim(@raw_expression) INTO @raw_expression;
  CALL trim(@operation) INTO @operation;

  -- Resolve PREV deterministically — never round-tripped through the LLM.
  -- Compare lower-cased on BOTH sides: EVALUATE lower-cases the right-hand
  -- literal but not the left-hand value, so 'PREV' = 'prev' would not match.
  CALL lower(@raw_expression) INTO @raw_expression_lc;
  EVALUATE @raw_expression_lc
    WHEN = 'prev' THEN
      @expression := @running_expression
    ELSE
      @expression := @raw_expression
  END

  CALL solve_step_with_sympy(@expression, @operation) INTO @step_summary;

  -- @step_summary stays '<bare_result>|<human_readable_line>' — the
  -- caller splits it the same way; '<bare_result>' is 'sympy_error'
  -- on failure, which the caller checks for explicitly (fail-fast).
  RETURN @step_summary
END;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW math_solver_ab
  INPUT @problem TEXT := 'differentiate 3*x**3 - x, then factor if needed, finally solve for x'
  INPUT @log_dir TEXT := 'cookbook/67_symbolic_math/logs-spl'

  -- The experiment switch. Any value other than 'true'/'1'/'yes' (case-
  -- insensitive) is treated as off — see the lower-cased EVALUATE below,
  -- which sidesteps the same case-sensitivity gotcha solve_chain_step
  -- works around for PREV.
  INPUT @enable_solver TEXT := 'true'

  OUTPUT @explanation TEXT
DO
  CALL lower(@enable_solver) INTO @solver_mode;

  -- NOTE: WHEN clauses MUST use `=`/`!=`/`IS`/`IS NOT` — a bare string
  -- literal (`WHEN 'true' THEN`) parses as a SemanticCondition and is
  -- judged by an LLM call ("does this text match 'true'? yes/no")
  -- rather than compared deterministically. `IS`/`IS NOT` are sugar
  -- for `=`/`!=` (added specifically for boolean-flavored switches like
  -- this one — "IS 'true'" reads more naturally than "= 'true'") and
  -- desugar to the same zero-token, case-insensitive boolean-shorthand
  -- comparison in the executor — exactly what a deterministic
  -- experiment-arm switch needs.
  EVALUATE @solver_mode
    WHEN IS 'true' THEN
      @use_solver := 'yes'
    WHEN IS '1' THEN
      @use_solver := 'yes'
    WHEN IS 'yes' THEN
      @use_solver := 'yes'
    ELSE
      @use_solver := 'no'
  END

  EVALUATE @use_solver
    WHEN = 'yes' THEN
      DO
        -- ════════════════════════════════════════════════════════
        -- ARM A — architecture: plan -> verified SymPy chain -> explain
        -- ════════════════════════════════════════════════════════
        LOGGING f"[arm=solver] Problem '@{@problem}' — planning the chain ..." LEVEL INFO

        GENERATE decompose_problem(@problem) INTO @steps_text;
        CALL trim(@steps_text) INTO @steps_text;
        CALL step_count(@steps_text) INTO @n_steps;

        LOGGING f"[arm=solver] decomposed into {@n_steps} step(s):\n{@steps_text}" LEVEL INFO

        -- ── Fail-fast checkpoint 1: the plan itself is unusable ──
        -- No steps parsed out of the LLM's response at all — this is
        -- a PLANNING failure. Exit now; do not ask the LLM to try
        -- explaining a chain that was never computed.
        EVALUATE @n_steps
          WHEN = '0' THEN
            LOGGING f'[arm=solver] PLAN FAILURE — decompose_problem produced no usable steps' LEVEL ERROR
            CALL write_file(f'{@log_dir}/chain_trace.md',
              f'(planning failed — raw decomposition output below)\n{@steps_text}') INTO NONE;
            RETURN f'[PLAN FAILURE] The planning step could not decompose "{@problem}" into usable operations.\nRaw decomposition output: {@steps_text}'
              WITH status = 'plan_error', arm = 'solver', steps = 0
        END

        @i := 0
        @running_expression := ''
        @trace := ''

        WHILE @i < @n_steps DO
          CALL extract_step(@steps_text, @i) INTO @step;
          CALL solve_chain_step(@step, @running_expression) INTO @step_summary;
          CALL split_part(@step_summary, '|', '1') INTO @running_expression;
          CALL split_part(@step_summary, '|', '2') INTO @trace_line;
          CALL trim(@running_expression) INTO @running_expression;
          CALL trim(@trace_line) INTO @trace_line;

          @step_no := @i + 1

          -- ── Fail-fast checkpoint 2: the kernel rejected this step ──
          -- The plan hand SymPy something it could not parse/compute —
          -- a SOLVER failure, traceable directly to a bad plan. Exit
          -- now, with the verified prefix preserved for diagnosis;
          -- do not let the LLM narrate around a broken chain (that
          -- is exactly the "graceful degradation" we want to MEASURE,
          -- not paper over, in this harness).
          EVALUATE @running_expression
            WHEN = 'sympy_error' THEN
              LOGGING f'[arm=solver] SOLVER FAILURE at step {@step_no}/{@n_steps}: {@trace_line}' LEVEL ERROR
              CALL write_file(f'{@log_dir}/chain_trace.md',
                f'{@trace}{@step_no}. SOLVER ERROR — {@trace_line}\n') INTO NONE;
              RETURN f'[SOLVER FAILURE] Step {@step_no}/{@n_steps} could not be computed: {@trace_line}\nVerified chain up to this point:\n{@trace}'
                WITH status = 'solver_error', arm = 'solver', steps = @step_no
          END

          @trace := @trace + f'{@step_no}. {@trace_line}\n'
          LOGGING f'[arm=solver][step {@step_no}/{@n_steps}] {@trace_line}' LEVEL INFO
          @i := @i + 1
        END

        CALL write_file(f'{@log_dir}/chain_trace.md', @trace) INTO NONE;

        GENERATE explain_chain(@problem, @trace) INTO @explanation;
        CALL trim(@explanation) INTO @explanation;

        -- ── Fail-fast checkpoint 3: the narration came back empty ──
        -- The chain verified cleanly but the EXPLANATION failed —
        -- exactly the "(no COMMIT)" pattern in case-2.md. Surface
        -- the verified chain itself (deterministic data already in
        -- hand) rather than asking the LLM for a second attempt —
        -- a retry is still a fallback to the same unreliable step.
        EVALUATE @explanation
          WHEN = '' THEN
            LOGGING f'[arm=solver] NARRATION FAILURE — explain_chain returned empty content' LEVEL ERROR
            RETURN f'[NARRATION FAILURE] The chain verified correctly but the explanation step returned nothing.\nVerified chain:\n{@trace}'
              WITH status = 'narration_error', arm = 'solver', steps = @n_steps
        END

        RETURN @explanation WITH status = 'complete', arm = 'solver', steps = @n_steps
      END

    ELSE
      DO
        -- ════════════════════════════════════════════════════════
        -- ARM B — baseline: no kernel; the LLM solves it, one shot
        -- ════════════════════════════════════════════════════════
        LOGGING f"[arm=llm_only] Problem '@{@problem}' — solving with NO symbolic kernel" LEVEL INFO

        CALL write_file(f'{@log_dir}/chain_trace.md',
          '(solver disabled for this run — no verified chain; the LLM solved it unaided)\n') INTO NONE;

        GENERATE solve_directly(@problem) INTO @explanation;
        CALL trim(@explanation) INTO @explanation;

        EVALUATE @explanation
          WHEN = '' THEN
            LOGGING f'[arm=llm_only] FAILURE — solve_directly returned empty content' LEVEL ERROR
            RETURN '[FAILURE] The unaided LLM returned nothing for this problem.'
              WITH status = 'llm_error', arm = 'llm_only', steps = 0
        END

        RETURN @explanation WITH status = 'complete', arm = 'llm_only', steps = 0
      END
  END
EXCEPTION
  WHEN BudgetExceeded THEN
    RETURN @explanation WITH status = 'budget_limit'
END;
