PROMPT classify_intent
SELECT @text AS input LIMIT 100 TOKENS,
       'intent' AS category
GENERATE classify(input, category) WITH OUTPUT BUDGET 200 TOKENS INTO @label;

WORKFLOW intent_handler
  INPUT @text TEXT
  OUTPUT @label TEXT
DO
  DO
    GENERATE classify(@text) INTO @label;
    COMMIT @label;
  EXCEPTION
    WHEN HallucinationDetected THEN
      @label := 'unknown';
      COMMIT @label;
  END;
END;