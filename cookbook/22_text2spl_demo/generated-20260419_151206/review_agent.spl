WORKFLOW refine_text
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := 0.0;
  @current := @draft;
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@current, style='improved') INTO @current;
    GENERATE sentiment(@current) INTO @quality;
    IF @quality > 0.7 THEN
      GENERATE suggest_improvement(@current) INTO @suggestion;
    ENDIF;
  END;
  @final := @current;
  COMMIT @final;
END;

CREATE FUNCTION rewrite(text TEXT, style TEXT)
RETURNS TEXT AS $$
  CASE style
    WHEN 'improved' THEN text || '.'
    WHEN 'standardized' THEN text || ', '
    ELSE text
  END;
$$;

CREATE FUNCTION suggest_improvement(text TEXT) RETURNS TEXT AS $$
  CASE
    WHEN text LIKE '%need% improvement%' THEN 'Consider rephrasing to improve clarity.'
    WHEN text LIKE '%is unclear%' THEN 'Check for ambiguity and ensure concision.'
    ELSE 'Text appears well-written. No suggestions needed.'
  END;
$$;

CREATE FUNCTION sentiment(text TEXT) RETURNS NUMBER AS $$
  CASE
    WHEN text LIKE '%good%' OR text LIKE '%great%' THEN 1.0
    WHEN text LIKE '%bad%' OR text LIKE '%terrible%' THEN -1.0
    ELSE 0.0
  END;
$$;

CREATE FUNCTION evaluate_quality(quality NUMBER) RETURNS BOOLEAN AS $$
  CASE
    WHEN quality >= 0.8 THEN TRUE
    WHEN quality > 0.7 THEN FALSE
    ELSE FALSE
  END;
$$;