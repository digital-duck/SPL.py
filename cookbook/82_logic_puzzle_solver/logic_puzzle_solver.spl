-- ============================================================
-- Recipe 82: Logic Puzzle Solver — LLM formulates, CSP solver proves
--
-- Extends the verifier ladder into a genuinely different verifier
-- CLASS: constraint satisfaction (CSP), not numeric optimization
-- (78's PuLP/LP) or symbolic algebra (67/75/77's SymPy/Sage).
-- Zebra-style logic puzzles ("who owns the zebra?") and Sudoku-lite
-- grids are classic CSPs — many candidate assignments, exactly one
-- (or zero, or several) satisfy every clue simultaneously.
--
--   Probabilistic (LLM)   — read the natural-language clues and write
--                            runnable python-constraint code
--   Deterministic (CSP)   — python-constraint's backtracking solver
--                            enumerates ALL solutions; no LLM guessing
--   Deterministic (ASSERT)— formal gate: only continue when the
--                            solver reports a UNIQUE solution
--   Probabilistic (LLM)   — narrate the solution, restating the
--                            final answer explicitly
--   Deterministic (round- — regex-and-compare classifier confirms the
--    trip classifier)       LLM's stated final answer matches the
--                            solver's ground truth (WITH roundtrip = ...)
--
-- @enable_solver = false is the unaided-LLM baseline arm — logic
-- puzzles are exactly where LLMs are known to silently violate a
-- clue while sounding confident; the CSP solver cannot.
--
-- Verifier choice: python-constraint (pure Python, no compiled
-- solver binary) over z3-solver — CSP puzzles like this one map
-- directly onto its Problem/Variable/Constraint vocabulary without
-- needing SMT theory reasoning, and it keeps the dependency light.
-- z3-solver is a fine alternative if a puzzle needs richer
-- arithmetic/boolean theories than plain finite-domain CSP.
--
-- Requires: pip install python-constraint
-- Run:
--   spl3 run cookbook/82_logic_puzzle_solver/logic_puzzle_solver.spl \
--       --llm claude_cli
--   spl3 run cookbook/82_logic_puzzle_solver/logic_puzzle_solver.spl \
--       --llm ollama:gemma3 --param enable_solver=false
-- ============================================================

-- ── Utility: timestamp + file I/O ───────────────────────────

CREATE TOOL_API now_ts()
RETURNS TEXT AS PYTHON $$
def now_ts() -> str:
    import datetime
    return datetime.datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
$$;

CREATE TOOL_API monotonic_now()
RETURNS TEXT AS PYTHON $$
def monotonic_now() -> str:
    import time
    return str(time.monotonic())
$$;

CREATE TOOL_API elapsed_secs(start_ts TEXT)
RETURNS TEXT AS PYTHON $$
def elapsed_secs(start_ts: str) -> str:
    import time
    try:
        return f"{time.monotonic() - float(start_ts):.1f}"
    except Exception:
        return "?"
$$;

-- ── Deterministic regime: python-constraint CSP solver tool ──

CREATE TOOL_API run_constraint(code TEXT)
RETURNS TEXT AS PYTHON $$
def run_constraint(code: str) -> str:
    """Execute LLM-generated python-constraint code and return a JSON result.

    The LLM writes the code; this function is the deterministic oracle.
    `Problem` and `AllDifferentConstraint` are already in scope. The code
    must set:
        _result = {"status": "Unique", "n_solutions": 1, "answer": <value>, ...}
        _result = {"status": "NoSolution", "n_solutions": 0}
        _result = {"status": "Ambiguous", "n_solutions": N}   (N > 1)
    On any error returns {"status": "Error", "error": "<msg>"}.
    """
    import json
    import re
    from constraint import Problem, AllDifferentConstraint
    code = re.sub(r'^```(?:python)?\s*\n?', '', code.strip(), flags=re.IGNORECASE)
    code = re.sub(r'\n?```\s*$', '', code)
    namespace = {"Problem": Problem, "AllDifferentConstraint": AllDifferentConstraint}
    try:
        exec(code, namespace)
        result = namespace.get("_result")
        if result is None:
            return json.dumps({"status": "Error",
                               "error": "code did not set _result"})
        return json.dumps(result, default=str)
    except Exception as e:
        return json.dumps({"status": "Error", "error": str(e)})
$$;

CREATE TOOL_API get_status(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def get_status(result_json: str) -> str:
    import json
    try:
        return json.loads(result_json).get("status", "Error")
    except Exception:
        return "Error"
$$;

CREATE TOOL_API get_error(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def get_error(result_json: str) -> str:
    import json
    try:
        d = json.loads(result_json)
        return d.get("error", d.get("status", "unknown error"))
    except Exception:
        return result_json
$$;

CREATE TOOL_API is_unique(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def is_unique(result_json: str) -> bool:
    """ASSERT gate: True only when the CSP solver found EXACTLY one
    solution consistent with every clue."""
    import json
    try:
        return json.loads(result_json).get("status") == "Unique"
    except Exception:
        return False
$$;

CREATE TOOL_API classify_roundtrip(narrative TEXT, result_json TEXT)
RETURNS TEXT AS PYTHON $$
def classify_roundtrip(narrative: str, result_json: str) -> str:
    """Round-trip check: does the LLM's own 'Final answer: ...' line, in
    its narration of the VERIFIED unique solution, actually match the
    solver's ground truth? Catches the LLM re-deriving (and getting
    wrong) a value it was already handed.

    Returns 'match' / 'mismatch' / 'unverifiable'.
    """
    import re
    import json
    m = re.search(r'final answer\s*:?\s*(.+)', narrative, re.IGNORECASE)
    if not m:
        return "unverifiable"
    llm_val = m.group(1).strip().rstrip('.').lower()
    try:
        truth = json.loads(result_json).get("answer")
    except Exception:
        return "unverifiable"
    if truth is None:
        return "unverifiable"
    truth_str = str(truth).strip().lower()
    if truth_str in llm_val or llm_val in truth_str:
        return "match"
    return "mismatch"
$$;

CREATE TOOL_API format_report(problem TEXT, code TEXT, solution_json TEXT,
                              narrative TEXT, roundtrip TEXT)
RETURNS TEXT AS PYTHON $$
def format_report(problem: str, code: str, solution_json: str,
                  narrative: str, roundtrip: str) -> str:
    import json
    try:
        sol = json.loads(solution_json)
    except Exception:
        sol = {}
    lines = [
        "# Logic Puzzle Report",
        "",
        f"**Puzzle:** {problem.strip()}",
        "",
        f"**CSP solver status:** `{sol.get('status', 'Unknown')}`",
        f"**Solutions found:** `{sol.get('n_solutions', '?')}`",
        f"**Ground-truth answer:** `{sol.get('answer', '?')}`",
        f"**Round-trip check:** `{roundtrip}`",
        "",
        "## Interpretation", "", narrative.strip(),
        "", "## Solver Code (LLM-generated, python-constraint)", "",
        "```python", code.strip(), "```",
    ]
    return "\n".join(lines)
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION formulate_csp_code(problem TEXT)
RETURNS TEXT AS $$
You are a constraint-satisfaction expert. Convert this logic puzzle into
runnable Python code using the `python-constraint` library.

Rules:
- `Problem` and `AllDifferentConstraint` are already imported and in scope
  — do NOT add import statements
- Model every category (e.g. color, nationality, drink) as one variable
  PER VALUE, each ranging over the house/position numbers (1..N), e.g.
      p.addVariable('color_Red', [1,2,3])
  then add an AllDifferentConstraint over each category's variables so
  no two values land in the same house
- Encode every clue as a p.addConstraint(...) call. "X is in house H" ->
  a constraint fixing that variable to H. "X's house = Y's house" ->
  a constraint that the two variables are equal. Relative clues
  ("immediately right of") -> a constraint on the numeric difference.
- After defining all variables and constraints, call p.getSolutions()
  and store the result EXACTLY as:
    _result = {"status": "Unique", "n_solutions": 1, "answer": <the specific
               value the puzzle asks for>, "houses": {...full assignment...}}
    (or "status": "NoSolution"/"Ambiguous" with the matching n_solutions,
    omitting "answer" if there is no unique one)
- IMPORTANT: p.addConstraint(...) takes EXACTLY TWO arguments — a
  function/lambda, and a list of the variable NAMES (strings) it applies
  to, e.g. p.addConstraint(lambda a, b: a == b, ['nation_Brit', 'color_Red'])
  — never pass a third positional argument to addConstraint
- The lambda's parameter count must exactly match the length of the
  variable-name list passed alongside it (one parameter per variable,
  in the same order); a single-variable constraint takes a 1-argument
  lambda, e.g. p.addConstraint(lambda a: a == 1, ['nation_Dane'])
- Output ONLY raw Python code — no markdown fences, no commentary

Worked example (a DIFFERENT, smaller puzzle — illustrates the API only,
do not reuse its clues): "2 houses, colors {Red,Blue}, pets {Cat,Dog}.
The Cat is in house 1. House 2 is not Red." ->
```python
p = Problem()
colors = ['Red', 'Blue']
pets = ['Cat', 'Dog']
for c in colors:
    p.addVariable(f'color_{c}', [1, 2])
for a in pets:
    p.addVariable(f'pet_{a}', [1, 2])
p.addConstraint(AllDifferentConstraint(), [f'color_{c}' for c in colors])
p.addConstraint(AllDifferentConstraint(), [f'pet_{a}' for a in pets])
p.addConstraint(lambda a: a == 1, ['pet_Cat'])
p.addConstraint(lambda a: a != 2, ['color_Red'])
solutions = p.getSolutions()
if len(solutions) == 1:
    sol = solutions[0]
    house_of = {}
    for h in [1, 2]:
        color = [c for c in colors if sol[f'color_{c}'] == h][0]
        pet = [a for a in pets if sol[f'pet_{a}'] == h][0]
        house_of[h] = {"color": color, "pet": pet}
    _result = {"status": "Unique", "n_solutions": 1,
               "answer": house_of[1]["color"], "houses": house_of}
elif len(solutions) == 0:
    _result = {"status": "NoSolution", "n_solutions": 0}
else:
    _result = {"status": "Ambiguous", "n_solutions": len(solutions)}
```

Puzzle: {problem}
$$;

CREATE FUNCTION repair_csp_code(problem TEXT, code TEXT, error_info TEXT)
RETURNS TEXT AS $$
This python-constraint code produced an error.

Puzzle: {problem}

Previous code:
{code}

Error:
{error_info}

Fix the code. Common causes:
- p.addConstraint(...) called with 3+ positional arguments — it takes
  EXACTLY TWO: a function/lambda, then a list of variable-name strings
  (e.g. p.addConstraint(lambda a, b: a == b, ['nation_Brit', 'color_Red']))
- A variable referenced in a constraint was never added with addVariable
- Constraint lambda arity does not match the number of variables passed
  (one lambda parameter per variable name in the list, same order)
- Missing or duplicate _result assignment
- Domain values that don't match the number of houses/positions

Output ONLY the corrected Python code — no markdown fences, no commentary.
$$;

CREATE FUNCTION interpret_csp_result(problem TEXT, solution_json TEXT)
RETURNS TEXT AS $$
You are a logic-puzzle expert. Interpret this VERIFIED constraint-solver
result for a general audience.

Puzzle: {problem}

Verified result (JSON, computed exactly by the CSP solver — trust it
completely, do not re-derive it):
{solution_json}

Provide a concise interpretation (under 100 words):
1. Restate what the puzzle asks
2. Give the answer, referencing the exact value from the JSON
3. One sentence citing a clue that pins it down

End your response with a line in EXACTLY this format (no extra words):
Final answer: <value>
$$;

CREATE FUNCTION solve_directly(problem TEXT)
RETURNS TEXT AS $$
Solve this logic puzzle: "{problem}"

There is no constraint solver backing you up this time — work through the
clues yourself, from scratch, in plain English.

Write a clear walkthrough in under 10 sentences that:
1. Restates the puzzle
2. Works through the clues step by step, showing how each one narrows
   down the possibilities
3. Gives the final answer plainly

End your response with a line in EXACTLY this format (no extra words):
Final answer: <value>
$$;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW logic_puzzle_solver
  -- Default: a compact 3-house zebra-style puzzle with a hand-verifiable
  -- unique solution (the Dane, in the green house, drinks coffee).
  INPUT @problem TEXT := "There are 3 houses in a row, numbered 1 to 3 from left to right. Each house has a unique color (Red, Green, Blue), is occupied by a person of a unique nationality (Brit, Swede, Dane), and that person drinks a unique beverage (Tea, Coffee, Milk). Clues: (1) The Brit lives in the Red house. (2) The Swede drinks Tea. (3) The Dane lives in house 1. (4) The owner of the Green house drinks Coffee. (5) The Blue house is house 2. Who drinks Coffee?"
  INPUT @enable_solver TEXT := "true"
  INPUT @max_tries INTEGER := 3
  INPUT @out_dir TEXT := "./cookbook/82_logic_puzzle_solver/output"
  OUTPUT @report TEXT
DO
  CALL monotonic_now() INTO @t_start;
  CALL now_ts() INTO @ts_safe;
  CALL lower(@enable_solver) INTO @solver_mode;
  LOGGING f"[logic_puzzle_solver] start run_id={@ts_safe} solver={@solver_mode}" LEVEL INFO

  EVALUATE @solver_mode
    WHEN IN ("true", "1", "yes") THEN
      @use_solver := "yes"
    ELSE
      @use_solver := "no"
  END

  EVALUATE @use_solver
    WHEN = "no" THEN
      DO
        -- ── ARM B: unaided LLM baseline — no CSP solver at all ──
        LOGGING "[arm=llm_only] solving with NO CSP solver" LEVEL INFO
        GENERATE solve_directly(@problem) INTO @report;
        CALL trim(@report) INTO @report;
        RETURN @report WITH status = "complete", arm = "llm_only", roundtrip = "not_applicable"
      END

    ELSE
      DO
        -- ── ARM A: LLM formulates CSP code; solver proves it ──
        LOGGING "[arm=solver] Stage 1 — LLM formulation + CSP solve" LEVEL INFO
        @tries    := 0;
        @status   := "init";
        @code     := "";
        @solution := "{}";

        WHILE @tries < @max_tries DO
          EVALUATE @status
            WHEN = "Unique" THEN
              @tries := @max_tries
            WHEN = "init" THEN
              DO
                GENERATE formulate_csp_code(@problem) INTO @code;
                CALL run_constraint(@code) INTO @solution;
                CALL get_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] attempt {@tries}: status={@status}" LEVEL INFO
              END
            ELSE
              DO
                CALL get_error(@solution) INTO @error_info;
                GENERATE repair_csp_code(@problem, @code, @error_info) INTO @code;
                CALL run_constraint(@code) INTO @solution;
                CALL get_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] repair {@tries}: status={@status}" LEVEL INFO
              END
          END
        END

        LOGGING f"[logic_puzzle_solver] Stage 2 — ASSERT gate (status={@status})" LEVEL INFO
        ASSERT is_unique(@solution);
        LOGGING "[logic_puzzle_solver] ASSERT passed — solver confirmed a unique solution" LEVEL INFO

        GENERATE interpret_csp_result(@problem, @solution) INTO @narrative;
        CALL classify_roundtrip(@narrative, @solution) INTO @roundtrip;
        LOGGING f"[logic_puzzle_solver] round-trip check: {@roundtrip}" LEVEL INFO

        CALL format_report(@problem, @code, @solution, @narrative, @roundtrip) INTO @report;
        CALL write_file(f"{@out_dir}/logic_puzzle_{@ts_safe}.md", @report) INTO @out_path;
        CALL elapsed_secs(@t_start) INTO @elapsed;
        LOGGING f"[logic_puzzle_solver] done — report -> {@out_path} ({@elapsed}s, attempts={@tries})" LEVEL INFO

        RETURN @report WITH status = "complete", arm = "solver", roundtrip = @roundtrip
      END
  END

EXCEPTION
  WHEN ToolFailed THEN
    @report := "CSP solver did not reach a Unique solution after " + @tries + " attempts. Last status: " + @status;
    CALL write_file(f"{@out_dir}/logic_puzzle_{@ts_safe}.md", @report) INTO @out_path;
    LOGGING f"[logic_puzzle_solver] failure — report -> {@out_path}" LEVEL INFO
    RETURN @report WITH status = "error", arm = "solver", roundtrip = "unverifiable"
END;
