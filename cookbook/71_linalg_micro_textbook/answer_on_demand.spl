-- Layer 4b: answer_on_demand.spl
-- Personalised concept slice: NL question → scoped, verified lesson.
-- Logical view (DODA): compile with
--   splc --lang python/linalg answer_on_demand.spl
--
-- Workflow:
--   1. Resolve the NL question to a target concept node (LLM).
--   2. Verify the target exists in the pre-built concept graph (deterministic).
--   3. Compute the learning gap: ancestors(target) minus already-mastered concepts.
--   4. Generate and verify one section per gap concept in productivity order.
--   5. Close with the target concept section.
--
-- Style: @style selects a profile from style_profiles.py.
--   resolve_target is style-agnostic (it resolves a concept name, not prose).
--   All content-generating calls receive @style_guide.

-- ── Prompt templates ────────────────────────────────────────────────────────

CREATE FUNCTION resolve_target(question TEXT, concept_list TEXT)
RETURN TEXT
AS $$
You are a linear algebra curriculum expert.

A student asked: {question}

Available concept nodes in the knowledge graph:
{concept_list}

Return the single concept name from the list above that best answers the
student's question. Output only the concept name as a bare identifier (e.g.
"eigenpair", "spectral_theorem"). No explanation. No punctuation.
$$;

CREATE FUNCTION write_section(concept TEXT, context TEXT, style_guide TEXT)
RETURN TEXT
AS $$
You are an expert linear algebra author writing a personalised micro-lesson.

{style_guide}

Write a self-contained section for the concept: {concept}
Surrounding context: {context}

Follow the structure and length specified in the STYLE GUIDE above exactly.
Use LaTeX for all mathematics.
Output only the section text. No preamble.
$$;

CREATE FUNCTION refine_section(section TEXT, feedback TEXT, style_guide TEXT)
RETURN TEXT
AS $$
You are an expert linear algebra author. Revise the section below based on
the feedback provided. Keep all correct content; fix only what is flagged.
Maintain the style described below throughout the revision.

{style_guide}

SECTION:
{section}

FEEDBACK:
{feedback}

Output the revised section only. No preamble. No commentary.
$$;

-- ── Main workflow ────────────────────────────────────────────────────────────

WORKFLOW answer_on_demand
    INPUT:
        @question TEXT DEFAULT 'Why does diagonalization work?',
        @style TEXT DEFAULT 'textbook',
        @learner_state LIST DEFAULT []
    OUTPUT:
        @lesson TEXT
DO
    -- 0. Timing instrumentation — wall-clock elapsed time per section and
    --    total, logged so runs can be profiled and compared (e.g. across
    --    distributed workers on Momagrid). See build_micro_textbook.spl for
    --    why _now()/_elapsed() (not time.time() directly) — both are defined
    --    in the python/linalg setup cell as bare-name wrappers.
    SOLVE @t_workflow_start FLOAT := _now()

    -- 1. Resolve style profile once (deterministic — no LLM involved)
    SOLVE @style_guide TEXT := style_instruction(@style)

    LOGGING f"Style: {@style}" LEVEL INFO

    -- 2. Resolve natural-language question to a concept node (style-agnostic)
    SOLVE @concept_list TEXT := str(concept_names())

    GENERATE resolve_target(@question, @concept_list) INTO @target

    -- 3. Verify the resolved target exists in the concept graph
    ASSERT in_graph(@graph, @target)
        OTHERWISE GENERATE resolve_target(@question, @concept_list) INTO @target

    LOGGING f"Target concept: {@target}" LEVEL INFO

    -- 4. Compute the personalised learning gap (ancestors minus mastered)
    SOLVE @order LIST := learning_path(@graph, @target, @learner_state, weight=1.0)

    SOLVE @order_len INT := len(@order)

    LOGGING f"Learning path: {@order_len} new concepts" LEVEL INFO

    -- 5. Generate and verify each gap concept in dependency order
    @lesson := ""
    @_i := 0

    WHILE @_i < @order_len DO
        SOLVE @concept TEXT := @order[@_i]
        SOLVE @t_section_start FLOAT := _now()

        LOGGING f"Generating: {@concept}" LEVEL INFO

        GENERATE write_section(@concept, @concept, @style_guide) INTO @section

        CALL verify_math(@section) INTO @check
        EVALUATE @check
            WHEN contains("fail") THEN
                GENERATE refine_section(@section, @check, @style_guide) INTO @section
            ELSE
                LOGGING f"Section {@concept} verified" LEVEL INFO
        END

        SOLVE @section_elapsed FLOAT := _elapsed(@t_section_start)
        LOGGING f"[timing] {@concept}: {@section_elapsed:.1f}s" LEVEL INFO

        @lesson := @lesson + "\n\n---\n\n" + @section
        @_i := @_i + 1
    END

    -- 6. Target concept capstone (styled)
    SOLVE @t_capstone_start FLOAT := _now()

    GENERATE write_section(@target, @target, @style_guide) INTO @capstone

    SOLVE @capstone_elapsed FLOAT := _elapsed(@t_capstone_start)
    LOGGING f"[timing] capstone ({@target}): {@capstone_elapsed:.1f}s" LEVEL INFO

    @lesson := @lesson + "\n\n---\n\n## " + @target + "\n\n" + @capstone

    SOLVE @total_elapsed FLOAT := _elapsed(@t_workflow_start)
    LOGGING f"[timing] workflow total: {@total_elapsed:.1f}s for {@order_len} concepts + capstone" LEVEL INFO

    LOGGING f"Lesson complete — style: {@style}, target: {@target}" LEVEL INFO

    COMMIT @lesson
END
