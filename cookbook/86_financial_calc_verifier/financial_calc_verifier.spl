-- ============================================================
-- Recipe 86: Financial Calculation Verifier — LLM formulates,
-- closed-form Decimal arithmetic proves it
--
-- Extends the verifier ladder into business-facing arithmetic —
-- compound interest, loan amortization — where LLMs are fluent at
-- describing the RIGHT formula in prose but routinely drop a term,
-- use the wrong compounding period, or round early and compound the
-- error. The verifier here is the closed-form formula itself,
-- recomputed with stdlib `decimal` (exact, no floating-point drift)
-- rather than trusting the LLM's own arithmetic.
--
--   Probabilistic (LLM)   — read the natural-language loan/interest
--                            problem and write runnable Decimal code
--                            implementing the correct closed-form formula
--   Deterministic (decimal— Python's Decimal module executes the
--    stdlib)                 arithmetic exactly, to fixed precision —
--                            no floating-point rounding drift
--   Deterministic (ASSERT)— formal gate: only continue when the
--                            calculation ran without error
--   Probabilistic (LLM)   — narrate the result, restating the
--                            final answer explicitly
--   Deterministic (round- — regex-and-compare classifier confirms the
--    trip classifier)       LLM's stated final answer matches the
--                            Decimal-computed ground truth (WITH
--                            roundtrip = ...)
--
-- @enable_solver = false is the unaided-LLM baseline arm — this is
-- close kin to recipe 48/49's credit-risk/regulatory-audit work but
-- ties the correctness check to arithmetic, not policy language.
--
-- Requires: stdlib `decimal` only — no new pip dependency
-- Run:
--   spl3 run cookbook/86_financial_calc_verifier/financial_calc_verifier.spl \
--       --llm claude_cli
--   spl3 run cookbook/86_financial_calc_verifier/financial_calc_verifier.spl \
--       --llm ollama:gemma3 --param enable_solver=false
-- ============================================================

-- ── Utility: timestamp + file I/O ───────────────────────────

CREATE TOOL_API now_ts()
RETURNS TEXT AS PYTHON $$
def now_ts() -> str:
    import datetime
    return datetime.datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
$$;

CREATE TOOL_API monotonic_now()
RETURNS TEXT AS PYTHON $$
def monotonic_now() -> str:
    import time
    return str(time.monotonic())
$$;

CREATE TOOL_API elapsed_secs(start_ts TEXT)
RETURNS TEXT AS PYTHON $$
def elapsed_secs(start_ts: str) -> str:
    import time
    try:
        return f"{time.monotonic() - float(start_ts):.1f}"
    except Exception:
        return "?"
$$;

-- ── Deterministic regime: exact Decimal arithmetic tool ──────

CREATE TOOL_API run_finance(code TEXT)
RETURNS TEXT AS PYTHON $$
def run_finance(code: str) -> str:
    """Execute LLM-generated Decimal-arithmetic code and return a JSON
    result dict. The LLM writes the code; this function is the
    deterministic oracle. `Decimal`, `getcontext`, and `ROUND_HALF_UP`
    are already in scope. The code must set:
        _result = {"status": "OK", "answer": "<final value as a string,
                   quantized to cents>", ...other useful fields...}
    On any error returns {"status": "Error", "error": "<msg>"}.
    """
    import json
    import re
    from decimal import Decimal, getcontext, ROUND_HALF_UP, InvalidOperation
    code = re.sub(r'^```(?:python)?\s*\n?', '', code.strip(), flags=re.IGNORECASE)
    code = re.sub(r'\n?```\s*$', '', code)
    getcontext().prec = 28
    namespace = {"Decimal": Decimal, "getcontext": getcontext,
                 "ROUND_HALF_UP": ROUND_HALF_UP}
    try:
        exec(code, namespace)
        result = namespace.get("_result")
        if result is None:
            return json.dumps({"status": "Error",
                               "error": "code did not set _result"})
        return json.dumps(result, default=str)
    except InvalidOperation as e:
        return json.dumps({"status": "Error", "error": f"InvalidOperation: {e}"})
    except Exception as e:
        return json.dumps({"status": "Error", "error": str(e)})
$$;

CREATE TOOL_API get_status(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def get_status(result_json: str) -> str:
    import json
    try:
        return json.loads(result_json).get("status", "Error")
    except Exception:
        return "Error"
$$;

CREATE TOOL_API get_error(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def get_error(result_json: str) -> str:
    import json
    try:
        d = json.loads(result_json)
        return d.get("error", d.get("status", "unknown error"))
    except Exception:
        return result_json
$$;

CREATE TOOL_API is_ok(result_json TEXT)
RETURNS TEXT AS PYTHON $$
def is_ok(result_json: str) -> bool:
    """ASSERT gate: True only when the Decimal calculation ran without error."""
    import json
    try:
        return json.loads(result_json).get("status") == "OK"
    except Exception:
        return False
$$;

CREATE TOOL_API classify_roundtrip(narrative TEXT, result_json TEXT)
RETURNS TEXT AS PYTHON $$
def classify_roundtrip(narrative: str, result_json: str) -> str:
    """Round-trip check: does the LLM's own 'Final answer: ...' line, in
    its narration of the VERIFIED Decimal result, match the ground-truth
    dollar figure (within 1 cent, or 0.5% relative for larger totals)?

    Returns 'match' / 'mismatch' / 'unverifiable'.
    """
    import re
    import json
    m = re.search(r'final answer\s*:?\s*(.+)', narrative, re.IGNORECASE)
    if not m:
        return "unverifiable"
    llm_val = m.group(1).strip().rstrip('.').lower()
    try:
        truth = json.loads(result_json).get("answer")
    except Exception:
        return "unverifiable"
    if truth is None:
        return "unverifiable"

    def _num(s):
        try:
            return float(re.sub(r'[^0-9.\-]', '', str(s)))
        except Exception:
            return None

    ln, tn = _num(llm_val), _num(truth)
    if ln is None or tn is None:
        return "unverifiable"
    abs_err = abs(ln - tn)
    if abs_err <= 0.01:
        return "match"
    if tn != 0 and abs_err / abs(tn) < 0.005:
        return "match"
    return "mismatch"
$$;

CREATE TOOL_API format_report(problem TEXT, code TEXT, solution_json TEXT,
                              narrative TEXT, roundtrip TEXT)
RETURNS TEXT AS PYTHON $$
def format_report(problem: str, code: str, solution_json: str,
                  narrative: str, roundtrip: str) -> str:
    import json
    try:
        sol = json.loads(solution_json)
    except Exception:
        sol = {}
    lines = [
        "# Financial Calculation Verification Report",
        "",
        f"**Problem:** {problem.strip()}",
        "",
        f"**Decimal-arithmetic status:** `{sol.get('status', 'Unknown')}`",
        f"**Ground-truth answer:** `${sol.get('answer', '?')}`",
        f"**Round-trip check:** `{roundtrip}`",
        "",
        "## Interpretation", "", narrative.strip(),
        "", "## Solver Code (LLM-generated, stdlib decimal)", "",
        "```python", code.strip(), "```",
    ]
    return "\n".join(lines)
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION formulate_finance_code(problem TEXT)
RETURNS TEXT AS $$
You are a financial-mathematics expert. Convert this word problem into
runnable Python code using the stdlib `decimal` module for EXACT
arithmetic (never floats for money).

Rules:
- `Decimal`, `getcontext`, and `ROUND_HALF_UP` are already in scope —
  do NOT add import statements
- Represent every dollar amount and rate as Decimal('...') constructed
  from a STRING literal (never Decimal(0.06), which inherits float
  imprecision) — e.g. Decimal('10000'), Decimal('0.06')
- Use the correct closed-form formula for the question:
    - Compound interest: A = P * (1 + r/n)^(n*t)
    - Loan amortization (fixed payment): M = P * r * (1+r)^N / ((1+r)^N - 1)
      where r is the PERIODIC rate and N is the number of payments
- Quantize every final dollar figure to cents with
  `.quantize(Decimal('0.01'), rounding=ROUND_HALF_UP)` before storing it
- Store the result EXACTLY as:
    _result = {
        "status": "OK",
        "answer": "<the specific figure the question asks for, as a
                   quantized-to-cents STRING>",
        ...any other useful intermediate figures as strings...
    }
- Output ONLY raw Python code — no markdown fences, no commentary

Problem: {problem}
$$;

CREATE FUNCTION repair_finance_code(problem TEXT, code TEXT, error_info TEXT)
RETURNS TEXT AS $$
This Decimal-arithmetic code produced an error.

Problem: {problem}

Previous code:
{code}

Error:
{error_info}

Fix the code. Common causes:
- Decimal(<float literal>) instead of Decimal('<string literal>')
- Mixing Decimal with a plain float in the same expression
  (Decimal only operates with Decimal, or with int)
- Wrong periodic rate (annual rate not divided by compounding periods
  per year before use)
- Missing or duplicate _result assignment
- Forgot .quantize(...) before storing the final answer as a string

Output ONLY the corrected Python code — no markdown fences, no commentary.
$$;

CREATE FUNCTION interpret_finance_result(problem TEXT, solution_json TEXT)
RETURNS TEXT AS $$
You are a financial advisor. Interpret this VERIFIED, exactly-computed
result for a general audience.

Problem: {problem}

Verified result (JSON, computed exactly with Decimal arithmetic — trust
it completely, do not re-derive it):
{solution_json}

Provide a concise interpretation (under 100 words):
1. Restate what the problem asks
2. State the answer as a dollar figure, referencing the exact value
   from the JSON
3. One sentence on which formula (compound interest / amortization) was used

End your response with a line in EXACTLY this format (no extra words,
number only, no dollar sign):
Final answer: <value>
$$;

CREATE FUNCTION solve_directly(problem TEXT)
RETURNS TEXT AS $$
A client asked this financial question: "{problem}"

There is no calculator or verifier backing you up this time — work it out
yourself, from scratch.

Write a clear walkthrough in under 8 sentences that:
1. Restates the problem
2. Shows your calculation step by step
3. Gives the final dollar answer plainly

End your response with a line in EXACTLY this format (no extra words,
number only, no dollar sign):
Final answer: <value>
$$;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW financial_calc_verifier
  -- Default: a standard fixed-rate loan amortization problem with a
  -- well-known reference monthly payment ($193.33/month on $10,000 at
  -- 6% APR over 5 years, monthly compounding) that is easy to get
  -- wrong by using the annual rate directly instead of dividing by 12.
  INPUT @problem TEXT := "A $10,000 loan has a 6% annual interest rate, compounded monthly, and is paid off in equal monthly installments over 5 years (60 months). What is the fixed monthly payment?"
  INPUT @enable_solver TEXT := "true"
  INPUT @max_tries INTEGER := 3
  INPUT @out_dir TEXT := "./cookbook/86_financial_calc_verifier/output"
  OUTPUT @report TEXT
DO
  CALL monotonic_now() INTO @t_start;
  CALL now_ts() INTO @ts_safe;
  CALL lower(@enable_solver) INTO @solver_mode;
  LOGGING f"[financial_calc_verifier] start run_id={@ts_safe} solver={@solver_mode}" LEVEL INFO

  EVALUATE @solver_mode
    WHEN IN ("true", "1", "yes") THEN
      @use_solver := "yes"
    ELSE
      @use_solver := "no"
  END

  EVALUATE @use_solver
    WHEN = "no" THEN
      DO
        -- ── ARM B: unaided LLM baseline — no Decimal verifier at all ──
        LOGGING "[arm=llm_only] solving with NO arithmetic verifier" LEVEL INFO
        GENERATE solve_directly(@problem) INTO @report;
        CALL trim(@report) INTO @report;
        RETURN @report WITH status = "complete", arm = "llm_only", roundtrip = "not_applicable"
      END

    ELSE
      DO
        -- ── ARM A: LLM formulates Decimal code; exact arithmetic proves it ──
        LOGGING "[arm=solver] Stage 1 — LLM formulation + Decimal compute" LEVEL INFO
        @tries    := 0;
        @status   := "init";
        @code     := "";
        @solution := "{}";

        WHILE @tries < @max_tries DO
          EVALUATE @status
            WHEN = "OK" THEN
              @tries := @max_tries
            WHEN = "init" THEN
              DO
                GENERATE formulate_finance_code(@problem) INTO @code;
                CALL run_finance(@code) INTO @solution;
                CALL get_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] attempt {@tries}: status={@status}" LEVEL INFO
              END
            ELSE
              DO
                CALL get_error(@solution) INTO @error_info;
                GENERATE repair_finance_code(@problem, @code, @error_info) INTO @code;
                CALL run_finance(@code) INTO @solution;
                CALL get_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] repair {@tries}: status={@status}" LEVEL INFO
              END
          END
        END

        LOGGING f"[financial_calc_verifier] Stage 2 — ASSERT gate (status={@status})" LEVEL INFO
        ASSERT is_ok(@solution);
        LOGGING "[financial_calc_verifier] ASSERT passed — Decimal arithmetic confirmed OK" LEVEL INFO

        GENERATE interpret_finance_result(@problem, @solution) INTO @narrative;
        CALL classify_roundtrip(@narrative, @solution) INTO @roundtrip;
        LOGGING f"[financial_calc_verifier] round-trip check: {@roundtrip}" LEVEL INFO

        CALL format_report(@problem, @code, @solution, @narrative, @roundtrip) INTO @report;
        CALL write_file(f"{@out_dir}/financial_calc_{@ts_safe}.md", @report) INTO @out_path;
        CALL elapsed_secs(@t_start) INTO @elapsed;
        LOGGING f"[financial_calc_verifier] done — report -> {@out_path} ({@elapsed}s, attempts={@tries})" LEVEL INFO

        RETURN @report WITH status = "complete", arm = "solver", roundtrip = @roundtrip
      END
  END

EXCEPTION
  WHEN ToolFailed THEN
    @report := "Decimal arithmetic did not complete cleanly after " + @tries + " attempts. Last status: " + @status;
    CALL write_file(f"{@out_dir}/financial_calc_{@ts_safe}.md", @report) INTO @out_path;
    LOGGING f"[financial_calc_verifier] failure — report -> {@out_path}" LEVEL INFO
    RETURN @report WITH status = "error", arm = "solver", roundtrip = "unverifiable"
END;
