-- ============================================================
-- Recipe 93: Automated Planning — LLM plans, a mini-VAL validator proves
--
-- Opens the Automated Planning (PDDL) application domain from the
-- post-TMLR roadmap: GENERATE plan -> CALL validator -> ASSERT valid
-- -> WHILE repair -> explain. The LLM's most common failure mode when
-- planning over a STRIPS-style domain isn't picking an unreasonable
-- action sequence — it's silently violating a precondition partway
-- through (e.g. unloading a package from a truck that isn't there,
-- or driving a truck that's already mid-route) while the overall plan
-- still LOOKS like it reaches the goal. A plan validator ("VAL" in
-- the planning literature) is the crisp, binary oracle: it replays
-- the plan action-by-action against the domain's precondition/effect
-- semantics and either the whole trace is legal or it isn't.
--
--   Probabilistic (LLM)   — read the natural-language logistics
--                            problem (fixed STRIPS domain given in
--                            the prompt) and propose a grounded plan
--                            as a JSON list of actions
--   Deterministic (VAL-   — replay the plan action-by-action: check
--    style validator)       each action's preconditions hold in the
--                            CURRENT state, apply its effects, repeat
--   Deterministic (ASSERT)— formal gate: only continue when every
--                            action's preconditions held AND the
--                            final state satisfies the goal
--   Probabilistic (LLM)   — narrate the result, restating the plan
--                            length explicitly
--   Deterministic (round- — regex-and-compare classifier confirms the
--    trip classifier)       LLM's stated final answer matches the
--                            validated plan's step count (WITH roundtrip = ...)
--
-- @enable_solver = false is the unaided-LLM baseline arm — the model
-- reasons about the plan in prose with no validator, exactly where
-- a precondition violation midway through a multi-step plan slips by
-- unnoticed.
--
-- Requires: stdlib json only — no new pip dependency
-- Run:
--   spl3 run cookbook/93_auto_planning/auto_planning.spl --llm claude_cli
--   spl3 run cookbook/93_auto_planning/auto_planning.spl \
--       --llm ollama:gemma3 --param enable_solver=false
-- ============================================================

-- ── Deterministic regime: STRIPS domain + mini-VAL plan validator ──

CREATE TOOL_API domain_description()
RETURNS TEXT AS PYTHON $$
def domain_description() -> str:
    """Fixed STRIPS logistics-lite domain, shown to the LLM (and to the
    unaided baseline arm) exactly as the ground truth the validator
    will replay the plan against."""
    return (
        "STRIPS DOMAIN: logistics-lite\n"
        "Objects: truck t1; packages p1, p2; locations A, B, C "
        "(any location reachable directly from any other — no roads to worry about)\n"
        "Predicates: truck_at(T, L), pkg_at(P, L), pkg_in(P, T)\n"
        "Actions (grounded, one per plan step):\n"
        "  {\"action\": \"drive\", \"truck\": T, \"from\": L1, \"to\": L2}\n"
        "    precondition: truck_at(T, L1)\n"
        "    effect: truck no longer at L1, truck now at L2\n"
        "  {\"action\": \"load\", \"truck\": T, \"pkg\": P, \"loc\": L}\n"
        "    precondition: truck_at(T, L) AND pkg_at(P, L)\n"
        "    effect: P no longer at L, P now in T\n"
        "  {\"action\": \"unload\", \"truck\": T, \"pkg\": P, \"loc\": L}\n"
        "    precondition: truck_at(T, L) AND pkg_in(P, T)\n"
        "    effect: P no longer in T, P now at L\n"
    )
$$;

CREATE TOOL_API run_plan_check(problem_json TEXT, plan_json TEXT)
RETURNS TEXT AS PYTHON $$
def run_plan_check(problem_json: str, plan_json: str) -> str:
    """Replay a proposed plan (a JSON list of grounded actions) against
    the logistics-lite STRIPS domain's precondition/effect semantics,
    starting from `problem_json`'s initial state, and check the goal.
    Acts as a minimal VAL-style plan validator: every action's
    preconditions must hold in the CURRENT simulated state before its
    effects are applied; if any precondition is violated, the plan is
    invalid at that step (with the reason reported for repair).
    """
    import json
    import re

    def strip_fences(s):
        s = re.sub(r'^```(?:json)?\s*\n?', '', s.strip(), flags=re.IGNORECASE)
        return re.sub(r'\n?```\s*$', '', s)

    try:
        problem = json.loads(strip_fences(problem_json))
        plan = json.loads(strip_fences(plan_json))
        if not isinstance(plan, list):
            return json.dumps({"status": "Error", "error": "plan must be a JSON list of actions", "step": 0})

        truck_at = dict(problem["truck_at"])          # {"t1": "A"}
        pkg_at = dict(problem.get("pkg_at", {}))       # {"p1": "A", "p2": "B"}
        pkg_in = dict(problem.get("pkg_in", {}))       # {} initially
        goal = problem["goal"]                         # {"pkg_at": {"p1": "C", "p2": "C"}}

        for i, step in enumerate(plan, start=1):
            act = step.get("action")
            if act == "drive":
                t, l1, l2 = step["truck"], step["from"], step["to"]
                if truck_at.get(t) != l1:
                    return json.dumps({
                        "status": "Error", "step": i,
                        "error": f"step {i} drive({t},{l1}->{l2}): precondition failed — "
                                 f"{t} is at '{truck_at.get(t)}', not '{l1}'",
                    })
                truck_at[t] = l2
            elif act == "load":
                t, p, l = step["truck"], step["pkg"], step["loc"]
                if truck_at.get(t) != l or pkg_at.get(p) != l:
                    return json.dumps({
                        "status": "Error", "step": i,
                        "error": f"step {i} load({p},{t}@{l}): precondition failed — "
                                 f"truck_at={truck_at.get(t)}, pkg_at={pkg_at.get(p)}, expected both '{l}'",
                    })
                del pkg_at[p]
                pkg_in[p] = t
            elif act == "unload":
                t, p, l = step["truck"], step["pkg"], step["loc"]
                if truck_at.get(t) != l or pkg_in.get(p) != t:
                    return json.dumps({
                        "status": "Error", "step": i,
                        "error": f"step {i} unload({p},{t}@{l}): precondition failed — "
                                 f"truck_at={truck_at.get(t)}, pkg_in={pkg_in.get(p)}, expected truck at '{l}' with pkg in '{t}'",
                    })
                del pkg_in[p]
                pkg_at[p] = l
            else:
                return json.dumps({"status": "Error", "step": i, "error": f"step {i}: unknown action '{act}'"})

        goal_pkg_at = goal.get("pkg_at", {})
        unmet = [f"{p} should be at {l} but is at {pkg_at.get(p, pkg_in.get(p, '?'))}"
                 for p, l in goal_pkg_at.items() if pkg_at.get(p) != l]
        if unmet:
            return json.dumps({
                "status": "Error", "step": len(plan),
                "error": "plan executed legally but goal not reached: " + "; ".join(unmet),
            })

        return json.dumps({
            "status": "OK",
            "answer": len(plan),
            "final_pkg_at": pkg_at,
            "final_truck_at": truck_at,
        })
    except KeyError as e:
        return json.dumps({"status": "Error", "step": 0, "error": f"malformed action, missing field {e}"})
    except Exception as e:
        return json.dumps({"status": "Error", "step": 0, "error": str(e)})
$$;

CREATE TOOL_API classify_roundtrip(narrative TEXT, result_json TEXT)
RETURNS TEXT AS PYTHON $$
def classify_roundtrip(narrative: str, result_json: str) -> str:
    """Round-trip check: does the LLM's own 'Final answer: ...' line, in
    its narration of the VALIDATED plan, match the verified plan length
    (number of steps)?

    Returns 'match' / 'mismatch' / 'unverifiable'.
    """
    import re
    import json
    m = re.search(r'final answer\s*:?\s*(.+)', narrative, re.IGNORECASE)
    if not m:
        return "unverifiable"
    llm_val = m.group(1).strip().rstrip('.')
    try:
        truth = json.loads(result_json).get("answer")
    except Exception:
        return "unverifiable"
    if truth is None:
        return "unverifiable"

    nums = re.findall(r'\d+', llm_val)
    if not nums:
        return "unverifiable"
    return "match" if int(nums[0]) == int(truth) else "mismatch"
$$;

CREATE TOOL_API format_report(problem TEXT, plan_json TEXT, solution_json TEXT,
                              narrative TEXT, roundtrip TEXT)
RETURNS TEXT AS PYTHON $$
def format_report(problem: str, plan_json: str, solution_json: str,
                  narrative: str, roundtrip: str) -> str:
    import json
    try:
        sol = json.loads(solution_json)
    except Exception:
        sol = {}
    lines = [
        "# Automated Planning Report",
        "",
        f"**Problem:** {problem.strip()}",
        "",
        f"**Validator status (VAL-style):** `{sol.get('status', 'Unknown')}`",
        f"**Plan length:** `{sol.get('answer', '?')} steps`",
        f"**Final package locations:** `{sol.get('final_pkg_at', '?')}`",
        f"**Round-trip check:** `{roundtrip}`",
        "",
        "## Interpretation", "", narrative.strip(),
        "", "## Proposed Plan (LLM-generated, JSON)", "",
        "```json", plan_json.strip(), "```",
    ]
    return "\n".join(lines)
$$;

-- ── Probabilistic regime: LLM prompt templates ───────────────

CREATE FUNCTION formulate_plan(domain TEXT, problem TEXT)
RETURNS TEXT AS $$
You are an automated planner. Given this STRIPS domain and problem,
produce a valid grounded plan.

{domain}

Problem: {problem}

Output ONLY a JSON list of grounded actions, each one of:
  {{"action": "drive", "truck": "t1", "from": "A", "to": "B"}}
  {{"action": "load", "truck": "t1", "pkg": "p1", "loc": "A"}}
  {{"action": "unload", "truck": "t1", "pkg": "p1", "loc": "C"}}

No markdown fences, no commentary — raw JSON array only.
$$;

CREATE FUNCTION repair_plan(domain TEXT, problem TEXT, plan_json TEXT, error_info TEXT)
RETURNS TEXT AS $$
This proposed plan is not VAL-valid — a precondition was violated (or
the goal was not reached) when the plan was replayed step by step.

{domain}

Problem: {problem}

Previous plan:
{plan_json}

Validator error:
{error_info}

Fix the plan so every action's precondition holds in the state at the
time it is executed, and the final state reaches the goal. Output
ONLY the corrected JSON list of grounded actions — no markdown fences,
no commentary.
$$;

CREATE FUNCTION interpret_plan_result(problem TEXT, solution_json TEXT)
RETURNS TEXT AS $$
You are an automated-planning expert. Interpret this VALIDATED plan
for a general audience.

Problem: {problem}

Verified result (JSON, independently replayed step-by-step against
the domain's precondition/effect semantics by a VAL-style validator —
trust it completely, do not re-derive it):
{solution_json}

Provide a concise interpretation (under 100 words):
1. Restate the logistics goal
2. State how many steps the validated plan took, referencing the
   exact value from the JSON
3. One sentence on why every precondition holding at each step matters
   (a plan that "looks right" can still violate one silently)

End your response with a line in EXACTLY this format (no extra words,
number only):
Final answer: <value>
$$;

CREATE FUNCTION solve_directly(domain TEXT, problem TEXT)
RETURNS TEXT AS $$
You are an automated planner. There is no plan validator backing you
up this time — work out a plan yourself, from scratch, and reason in
prose about whether each step's precondition holds.

{domain}

Problem: {problem}

Write a clear step-by-step plan in under 10 sentences, explicitly
checking each action's precondition against the state at that point.
State the final number of steps in the plan plainly.

End your response with a line in EXACTLY this format (no extra words,
number only):
Final answer: <value>
$$;

-- ── WORKFLOW ─────────────────────────────────────────────────

WORKFLOW auto_planning
  -- Default: logistics-lite problem with a known minimal plan
  -- (5 steps): drive t1 A->B; load p2@B; drive t1 B->A; load p1@A;
  -- drive t1 A->C; unload p1@C; unload p2@C -- shortest legal plan
  -- delivers both packages to C.
  INPUT @problem_text TEXT := "Truck t1 starts at A. Package p1 starts at A, package p2 starts at B. Deliver BOTH packages to location C using t1 (t1 can carry any number of packages at once; it can drive directly between any two locations)."
  INPUT @problem_json TEXT := "{\"truck_at\": {\"t1\": \"A\"}, \"pkg_at\": {\"p1\": \"A\", \"p2\": \"B\"}, \"pkg_in\": {}, \"goal\": {\"pkg_at\": {\"p1\": \"C\", \"p2\": \"C\"}}}"
  INPUT @enable_solver TEXT := "true"
  INPUT @max_tries INTEGER := 4
  INPUT @out_dir TEXT := "./cookbook/93_auto_planning/output"
  OUTPUT @report TEXT
DO
  CALL time_monotonic() INTO @t_start;
  CALL time_now() INTO @ts_safe;
  CALL lower(@enable_solver) INTO @solver_mode;
  CALL domain_description() INTO @domain;
  LOGGING f"[auto_planning] start run_id={@ts_safe} solver={@solver_mode}" LEVEL INFO

  EVALUATE @solver_mode
    WHEN IN ("true", "1", "yes") THEN
      @use_solver := "yes"
    ELSE
      @use_solver := "no"
  END

  EVALUATE @use_solver
    WHEN = "no" THEN
      DO
        -- ── ARM B: unaided LLM baseline — no plan validator ──
        LOGGING "[arm=llm_only] planning with NO validator" LEVEL INFO
        GENERATE solve_directly(@domain, @problem_text) INTO @report;
        CALL trim(@report) INTO @report;
        RETURN @report WITH status = "complete", arm = "llm_only", roundtrip = "not_applicable"
      END

    ELSE
      DO
        -- ── ARM A: LLM proposes plan; VAL-style validated ──
        LOGGING "[arm=solver] Stage 1 — LLM plan proposal + validation" LEVEL INFO
        @tries    := 0;
        @status   := "init";
        @plan     := "[]";
        @solution := "{}";

        WHILE @tries < @max_tries DO
          EVALUATE @status
            WHEN = "OK" THEN
              @tries := @max_tries
            WHEN = "init" THEN
              DO
                GENERATE formulate_plan(@domain, @problem_text) INTO @plan;
                CALL run_plan_check(@problem_json, @plan) INTO @solution;
                CALL result_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] attempt {@tries}: status={@status}" LEVEL INFO
              END
            ELSE
              DO
                CALL result_error(@solution) INTO @error_info;
                GENERATE repair_plan(@domain, @problem_text, @plan, @error_info) INTO @plan;
                CALL run_plan_check(@problem_json, @plan) INTO @solution;
                CALL result_status(@solution) INTO @status;
                @tries := @tries + 1;
                LOGGING f"[arm=solver] repair {@tries}: status={@status}" LEVEL INFO
              END
          END
        END

        LOGGING f"[auto_planning] Stage 2 — ASSERT gate (status={@status})" LEVEL INFO
        ASSERT result_ok(@solution);
        LOGGING "[auto_planning] ASSERT passed — plan is VAL-valid" LEVEL INFO

        GENERATE interpret_plan_result(@problem_text, @solution) INTO @narrative;
        CALL classify_roundtrip(@narrative, @solution) INTO @roundtrip;
        LOGGING f"[auto_planning] round-trip check: {@roundtrip}" LEVEL INFO

        CALL format_report(@problem_text, @plan, @solution, @narrative, @roundtrip) INTO @report;
        CALL write_file(f"{@out_dir}/plan_{@ts_safe}.md", @report) INTO @out_path;
        CALL time_elapsed(@t_start) INTO @elapsed;
        LOGGING f"[auto_planning] done — report -> {@out_path} ({@elapsed}s, attempts={@tries})" LEVEL INFO

        RETURN @report WITH status = "complete", arm = "solver", roundtrip = @roundtrip
      END
  END

EXCEPTION
  WHEN ToolFailed THEN
    @report := "No VAL-valid plan found after " + @tries + " attempts. Last status: " + @status;
    CALL write_file(f"{@out_dir}/plan_{@ts_safe}.md", @report) INTO @out_path;
    LOGGING f"[auto_planning] failure — report -> {@out_path}" LEVEL INFO
    RETURN @report WITH status = "error", arm = "solver", roundtrip = "unverifiable"
END;
