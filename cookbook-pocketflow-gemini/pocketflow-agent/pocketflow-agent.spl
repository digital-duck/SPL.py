CREATE FUNCTION DecideAction(query TEXT, context TEXT) RETURNS TEXT AS $$
Given the query: {query} and the current context: {context}, decide whether to 'search' for more information or 'answer' the question.
If searching, provide a concise search query. If answering, provide the answer.
Output format:
If you need to search: search: [your search query]
If you are ready to answer: answer: [your final answer]
$$;

CREATE FUNCTION AnswerQuestion(query TEXT, context TEXT) RETURNS TEXT AS $$
Given the original query: {query} and the gathered information: {context}, provide a comprehensive answer.
$$;

WORKFLOW pocketflow_agent
  INPUT @initial_query TEXT
  OUTPUT @final_answer TEXT
DO
  @context := @initial_query;
  @iteration := 0;
  @max_iterations := 3;

  WHILE @iteration < @max_iterations DO
    GENERATE DecideAction(@initial_query, @context) INTO @action;

    EVALUATE @action
      WHEN contains('answer:') THEN
        GENERATE AnswerQuestion(@initial_query, @context) INTO @final_answer;
        RETURN @final_answer WITH status = 'complete';
      ELSE
        CALL web_search(@action) INTO @results;
        @context := @context + "\nSearch Results:\n" + @results;
        @iteration := @iteration + 1;
    END;
  END;

  GENERATE AnswerQuestion(@initial_query, @context) INTO @final_answer;
  RETURN @final_answer WITH status = 'max_iterations_reached';
END;
