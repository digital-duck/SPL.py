CREATE FUNCTION DecideAction(user_query TEXT, context TEXT)
RETURNS TEXT AS $$
Given the question: {user_query}
Current research context: {context}

Decide if you need to perform a web search to gather more information, or if you have enough information to answer.
Respond with exactly one word: 'search' or 'answer'.
$$;

CREATE FUNCTION AnswerQuestion(user_query TEXT, context TEXT)
RETURNS TEXT AS $$
Based on the question: {user_query}
And the gathered context: {context}

Synthesize a final comprehensive response to the question.
$$;

WORKFLOW ResearchAssistant
  INPUT @user_query TEXT
  OUTPUT @final_response TEXT
DO
  @context := "No information gathered yet";
  @action := "search";
  @iteration := 0;

  WHILE @action = "search" AND @iteration < 5 DO
    GENERATE DecideAction(@user_query, @context) INTO @action;

    EVALUATE @action
      WHEN contains("search") THEN
        CALL search_web(@user_query) INTO @search_results;
        @context := @context + "\nNew Findings: " + @search_results;
        @iteration := @iteration + 1;
      ELSE
        @action := "done";
    END;
  END;

  GENERATE AnswerQuestion(@user_query, @context) INTO @final_response;

  RETURN @final_response WITH status = "complete";
END;
