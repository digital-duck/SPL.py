      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "neurips_26_lab_notes_mmd2spl_fence_strip",
      "label": "mmd2spl fence-stripping (line-based, cmd_mmd2spl)",
      "file_type": "code",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Regex-based fence stripping failed when LLM added preamble prose before code blocks or embedded inner fences (e.g. ```yaml inside CREATE FUNCTION bodies). Replaced with line-based stripping that scans for opening fence anywhere in response and only trims first/last fence lines."
    },
    {
      "id": "neurips_26_lab_notes_spl_executor_while_bug",
      "label": "WHILE condition string comparison fix (spl/executor.py)",
      "file_type": "code",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Executor silently set should_continue=False when float() conversion failed on string operands in WHILE conditions. Fixed by adding string comparison fallback after float failure."
    },
    {
      "id": "neurips_26_lab_notes_compound_condition",
      "label": "CompoundCondition (AND/OR WHILE guards)",
      "file_type": "code",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "AND/OR handler discarded right-hand sub-conditions, only evaluating left side. Added CompoundCondition dataclass to ast_nodes.py and rewrote _parse_while_condition to accumulate all arms."
    },
    {
      "id": "neurips_26_lab_notes_qwen_double_brace_bug",
      "label": "Qwen double-brace template variable bug ({{param}} vs {param})",
      "file_type": "concept",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "qwen3.6-plus systematically used {{param}} double-braces in CREATE FUNCTION body templates. SPL executor substitutes via body.replace('{'+key+'}', val), so double-braces never match and variables are never injected into prompts at runtime. Silent failure affecting all 5 recipes."
    },
    {
      "id": "neurips_26_lab_notes_splc_environment_blind",
      "label": "splc Context-Free Transpiler Limitation",
      "file_type": "rationale",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "spl3 splc compile generates structurally plausible code but has no access to target framework API details, tool availability, adapter configuration, or dependency chain. Results in stubs, outdated API names (Workflow vs Flow), wrong model IDs, and mock implementations. S4 human review is a mandatory pipeline step."
    },
