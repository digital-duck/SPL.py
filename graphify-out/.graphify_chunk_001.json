    {
      "id": "neurips_26_lab_notes_call_parallel_misuse",
      "label": "CALL PARALLEL misuse with CREATE FUNCTION (Gemini pattern)",
      "file_type": "concept",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Gemini placed LLM-backed CREATE FUNCTIONs inside CALL PARALLEL blocks which only accepts tool CALLs. Executor rejects CallParallelStatement, silently skipping the blocks. Claude and Qwen never made this error."
    },
