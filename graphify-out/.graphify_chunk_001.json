    {
      "id": "neurips_26_lab_notes_mermaid_syntax_bugs",
      "label": "Mermaid Syntax Bug Patterns (LLM generation)",
      "file_type": "concept",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "LLMs frequently generate invalid Mermaid syntax: \\n in unquoted labels, Unicode arrows, hexagon double-braces for decision nodes, subgraph-name edge targets, dotted-edge-with-label syntax errors. Post-processing via fix_mermaid_syntax() and prompt corrections applied at source in spl3/cli.py."
    },
    {
      "id": "neurips_26_lab_notes_spl3_cli_fix_mermaid",
      "label": "fix_mermaid_syntax() post-processor (spl3/cli.py)",
      "file_type": "code",
      "source_file": "NeurIPS-26-lab/notes.md",
      "source_location": null,
