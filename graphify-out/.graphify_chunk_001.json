    {
      "id": "neurips_26_lab_readme_full_ir_pipeline",
      "label": "Full IR Pipeline (S1→S6)",
      "file_type": "concept",
      "source_file": "NeurIPS-26-lab/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Intermediate representation steps (Mermaid diagram + SPL workflow) are hypothesized to improve round-trip fidelity vs. direct NL-to-code generation. The IR pipeline enforces structured, reviewable artifacts at each stage, enabling human-in-the-loop correction before errors propagate."
    },
    {
      "id": "neurips_26_lab_readme_ablation_pipeline",
      "label": "Ablation Pipeline (S7→S10, Vibe Coding Bypass)",
      "file_type": "concept",
      "source_file": "NeurIPS-26-lab/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Bypasses Mermaid + SPL IR steps via spl3 vibe (text→code directly). Serves as a baseline to measure quality loss without intermediate representation, enabling calculation of delta-IR = S6 score − S9 score."
    },
    {
      "id": "neurips_26_lab_readme_human_checkpoint_protocol",
      "label": "Human Checkpoint Protocol (Review-Run-Document)",
      "file_type": "rationale",
      "source_file": "NeurIPS-26-lab/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mandatory three-step gate at every stage: (1) Review generated artifact, (2) Run with real inputs and fix all issues, (3) Document in notes.md before proceeding. Prevents LLM drift from compounding silently through downstream steps."
