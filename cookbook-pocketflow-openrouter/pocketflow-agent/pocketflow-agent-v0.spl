CREATE FUNCTION decide_action(question TEXT, context TEXT) RETURNS TEXT AS $$
Based on the current research question and accumulated context, decide the next action.
Return your decision in this exact YAML format:

action: search|answer
reasoning: brief explanation
search_query: specific query (only if action is search)

Question: {question}
Current context: {context}

If you have sufficient information to provide a comprehensive answer, choose "answer".
If you need more specific information, choose "search" and provide a focused search query.
$$;

CREATE FUNCTION search_web(query TEXT) RETURNS TEXT AS $$
Search for: {query}
$$;

CREATE FUNCTION generate_final_answer(question TEXT, context TEXT) RETURNS TEXT AS $$
Based on all the research gathered, provide a comprehensive answer to the question.

Question: {question}
Research context: {context}

Provide a detailed, well-structured response that synthesizes all available information.
$$;

WORKFLOW research_agent
  INPUT @question TEXT, @max_iterations INTEGER := 3
  OUTPUT @answer TEXT
DO
  @iteration := 0;
  @context := '';
  @search_query := '';
  
  WHILE @iteration < @max_iterations DO
    DO
      GENERATE decide_action(@question, @context) INTO @decision;
      
      EVALUATE @decision
        WHEN contains('action: search') THEN
          @iteration := @iteration + 1;
          GENERATE extract_entities(@decision) INTO @query_data;
          CALL web_search(@query_data) INTO @search_results;
          @context := @context + '\n' + @search_results;
        WHEN contains('action: answer') THEN
          GENERATE generate_final_answer(@question, @context) INTO @answer;
          RETURN @answer WITH status = 'complete', iterations = @iteration;
        ELSE
          @iteration := @iteration + 1;
          @context := @context + '\nDecision parsing failed, continuing search.';
      END;
      
    EXCEPTION
      WHEN HallucinationDetected THEN
        @iteration := @iteration + 1;
        @context := @context + '\nRetrying due to hallucination detected.';
      WHEN ModelOverloaded THEN
        RETRY;
    END;
  END;
  
  GENERATE generate_final_answer(@question, @context) INTO @answer;
  RETURN @answer WITH status = 'max_iterations', iterations = @iteration;
  
EXCEPTION
  WHEN BudgetExceeded THEN
    GENERATE generate_final_answer(@question, @context) INTO @answer;
    RETURN @answer WITH status = 'budget_exceeded';
END;