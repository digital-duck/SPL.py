# SPL environment configuration — copy to .env and fill in your values.
# Load with: source .env   OR   export $(grep -v '^#' .env | xargs)

# ── Default adapter & model ────────────────────────────────────────────────────
# Controls which adapter/model is used when the .spl file omits USING MODEL.
# Adapter choices: claude_cli | ollama | openrouter | anthropic | openai |
#                  google | qwen | deepseek | momagrid | bedrock | azure_openai
SPL_DEFAULT_ADAPTER=claude_cli
SPL_DEFAULT_MODEL=claude-sonnet-4-6

# ── WHILE loop safety caps ─────────────────────────────────────────────────────
# Increase SPL_WHILE_MAX_ITER if concept-book generation hits "exceeded N iterations".
# The default (15) is conservative; concept-book workflows often need 30–50.
SPL_WHILE_MAX_ITER=30

# ── LLM call & token safety caps ──────────────────────────────────────────────
SPL_MAX_LLM_CALLS=50
SPL_MAX_TOTAL_TOKENS=200000

# ── LLM request timeout (seconds) ─────────────────────────────────────────────
SPL_LLM_TIMEOUT=600

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# SPL_OLLAMA_URL is used by the splc transpiler (domain-graph compilation).
SPL_OLLAMA_URL=http://localhost:11434
# Model used by splc transpiler when no --llm flag is given.
SPL_MODEL=llama3.2

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Google (Gemini) ───────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Qwen / Alibaba DashScope ──────────────────────────────────────────────────
DASHSCOPE_API_KEY=

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Momagrid (distributed inference) ──────────────────────────────────────────
MOMAGRID_HUB_URL=http://localhost:9000
MOMAGRID_API_KEY=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=

# ── Ubuntu Snap inference runtime ─────────────────────────────────────────────
UBUNTU_AI_URL=http://localhost:12000

# ── PostgreSQL persistence backend ────────────────────────────────────────────
# Only needed if using the postgres persistence backend (spl3 configure set backend=postgres).
SPL_PG_DSN=postgresql://user:password@localhost:5432/spl

# ── Lean / Elan (formal proof backend) ────────────────────────────────────────
# ELAN_HOME is set automatically by elan; override only if using a non-standard install.
# ELAN_HOME=~/.elan
SPL_LEAN_REPL_DIR=
SPL_LEAN_PROJECT_DIR=
