CREATE FUNCTION planner(topic TEXT) RETURNS TEXT AS $$
Generate 3-5 diverse search queries to research the topic: {topic}
Format as a comma-separated list of specific, focused search terms.
$$;

CREATE FUNCTION researcher(queries TEXT) RETURNS TEXT AS $$
For each search query in this list: {queries}
Perform web research and extract 2-3 key facts per query.
Combine all findings into a structured list of research notes.
$$;

CREATE FUNCTION synthesizer(topic TEXT, notes TEXT) RETURNS TEXT AS $$
Analyze these research notes for the topic "{topic}": {notes}
Reply with exactly [COMPLETE] if the research comprehensively covers the topic,
otherwise reply with [GAPS] followed by specific areas that need more investigation.
$$;

WORKFLOW research_pipeline
  INPUT @topic TEXT
  OUTPUT @report TEXT
DO
  @iteration := 0;
  @max_iterations := 2;
  @all_notes := '';
  @feedback := '';
  
  WHILE @iteration < @max_iterations DO
    DO
      @iteration := @iteration + 1;
      
      GENERATE planner(@topic) INTO @queries;
      GENERATE researcher(@queries) INTO @current_notes;
      @all_notes := @all_notes + '\n' + @current_notes;
      
      GENERATE synthesizer(@topic, @all_notes) INTO @feedback;
      
      EVALUATE @feedback
        WHEN contains('[COMPLETE]') THEN
          GENERATE summarize(@all_notes, 'markdown_report') INTO @report;
          RETURN @report WITH status = 'complete', iterations = @iteration;
        WHEN contains('[GAPS]') THEN
          @topic := @topic + ' focusing on: ' + @feedback;
        ELSE
          GENERATE summarize(@all_notes, 'markdown_report') INTO @report;
          RETURN @report WITH status = 'uncertain', iterations = @iteration;
      END;
      
    EXCEPTION
      WHEN ModelOverloaded THEN
        RETRY;
      WHEN BudgetExceeded THEN
        GENERATE summarize(@all_notes, 'markdown_report') INTO @report;
        RETURN @report WITH status = 'budget_exceeded', iterations = @iteration;
    END;
  END;
  
  GENERATE summarize(@all_notes, 'markdown_report') INTO @report;
  RETURN @report WITH status = 'max_iterations', iterations = @iteration;
  
EXCEPTION
  WHEN NodeUnavailable THEN
    @report := 'Research pipeline unavailable. Please try again later.';
    RETURN @report WITH status = 'error', iterations = @iteration;
END;